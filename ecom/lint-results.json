roduct.deliveryType) return null;\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 104 |\n      Г”ГҮВӘ\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 142 |     );\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 143 |   };\n      | ^^^^ The component is created during render here\n  144 |\n  145 |   // Card Content based on variant\n  146 |   if (variant === 'compact') {","line":360,"column":16,"nodeType":null,"endLine":360,"endColumn":29}],"suppressedMessages":[],"errorCount":5,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport Link from 'next/link';\nimport Image from 'next/image';\nimport { useState } from 'react';\nimport {\n  ShoppingCart,\n  Heart,\n  Scale,\n  Eye,\n  Star,\n  Zap,\n  ChevronDown,\n} from 'lucide-react';\nimport { Button } from '@/components/ui/button';\nimport { Badge } from '@/components/ui/badge';\nimport { Card, CardContent } from '@/components/ui/card';\nimport { RatingStars } from '@/components/ui/rating-stars';\nimport { PriceDisplay } from '@/components/ui/currency-display';\nimport { cn, getLocalizedValue } from '@/lib/utils';\n\ninterface Platform {\n  name: string;\n  nameAr: string;\n  slug: string;\n  icon?: string;\n}\n\ninterface Product {\n  id: string;\n  name: string;\n  nameAr: string;\n  slug: string;\n  price: number;\n  compareAtPrice?: number;\n  rating: number;\n  ratingCount: number;\n  platform: Platform;\n  isNew?: boolean;\n  isFeatured?: boolean;\n  onSale?: boolean;\n  pointsReward: number;\n  deliveryType?: 'auto_key' | 'auto_account' | 'manual' | 'contact';\n  image?: string;\n}\n\ninterface ProductCardProps {\n  product: Product;\n  locale: string;\n  onAddToCart?: (productId: string) => void;\n  onToggleWishlist?: (productId: string) => void;\n  onToggleCompare?: (productId: string) => void;\n  isWishlisted?: boolean;\n  isComparing?: boolean;\n  variant?: 'default' | 'compact' | 'featured';\n}\n\nexport function ProductCard({\n  product,\n  locale,\n  onAddToCart,\n  onToggleWishlist,\n  onToggleCompare,\n  isWishlisted = false,\n  isComparing = false,\n  variant = 'default',\n}: ProductCardProps) {\n  const isRTL = locale === 'ar';\n  const [isImageLoaded, setIsImageLoaded] = useState(false);\n  const [showQuickActions, setShowQuickActions] = useState(false);\n\n  const discountPercent =\n    product.compareAtPrice && product.price < product.compareAtPrice\n      ? Math.round(((product.compareAtPrice - product.price) / product.compareAtPrice) * 100)\n      : 0;\n\n  // Platform Icon Component\n  const PlatformIcon = () => {\n    const platformIcons: Record<string, string> = {\n      steam: 'ВӯЖ’Г„В«',\n      playstation: 'ВӯЖ’Г„В»',\n      ps: 'ВӯЖ’Г„В»',\n      psn: 'ВӯЖ’Г„В»',\n      xbox: 'ВӯЖ’Ж’Гі',\n      nintendo: 'ВӯЖ’Г¶в”Ө',\n      switch: 'ВӯЖ’Г¶в”Ө',\n      netflix: 'ВӯЖ’Г„Вј',\n      spotify: 'ВӯЖ’Г„ГҒ',\n      ai: 'ВӯЖ’ГұГ»',\n      default: 'ВӯЖ’ГҶГ„',\n    };\n\n    const icon =\n      product.platform?.icon ||\n      (product.platform?.slug && platformIcons[product.platform.slug.toLowerCase()]) ||\n      platformIcons.default;\n\n    return <span className=\"text-lg\">{icon}</span>;\n  };\n\n  // Delivery Type Badge\n  const DeliveryBadge = () => {\n    if (!product.deliveryType) return null;\n\n    const deliveryConfig = {\n      auto_key: {\n        icon: Zap,\n        label: locale === 'ar' ? 'ГҸВ¬в”ҳГӘГҸГҒв”ҳГЁв”ҳГӨ в”ҳГјв”ҳГӘГҸв–’в”ҳГЁ' : 'Instant',\n        variant: 'success' as const,\n      },\n      auto_account: {\n        icon: Zap,\n        label: locale === 'ar' ? 'ГҸВЎГҸв”ӮГҸВәГҸВҝ в”ҳГјв”ҳГӘГҸв–’в”ҳГЁ' : 'Instant Account',\n        variant: 'success' as const,\n      },\n      manual: {\n        icon: ChevronDown,\n        label: locale === 'ar' ? 'в”ҳГЁГҸВ»в”ҳГӘв”ҳГЁ' : 'Manual',\n        variant: 'warning' as const,\n      },\n      contact: {\n        icon: null,\n        label: locale === 'ar' ? 'ГҸВ¬в”ҳГӘГҸВәГҸГҒв”ҳГӨ' : 'Contact',\n        variant: 'info' as const,\n      },\n    };\n\n    const config = deliveryConfig[product.deliveryType];\n    if (!config) return null;\n\n    const Icon = config.icon;\n\n    return (\n      <Badge\n        variant={config.variant}\n        size=\"sm\"\n        className=\"gap-1\"\n      >\n        {Icon && <Icon className=\"w-3 h-3\" />}\n        {config.label}\n      </Badge>\n    );\n  };\n\n  // Card Content based on variant\n  if (variant === 'compact') {\n    return (\n      <Link\n        href={`/${locale}/products/${product.slug}`}\n        className=\"block group\"\n      >\n        <div className=\"flex gap-4 p-3 rounded-xl bg-card hover:bg-card-hover transition-all duration-300 border border-border/50 hover:border-border\">\n          {/* Image */}\n          <div className=\"relative w-20 h-20 flex-shrink-0 rounded-lg overflow-hidden bg-background-lighter\">\n            {product.image ? (\n              <img\n                src={product.image}\n                alt={getLocalizedValue(product.name, product.nameAr, locale)}\n                className={cn(\n                  'w-full h-full object-cover transition-transform duration-500',\n                  isImageLoaded && 'loaded'\n                )}\n                onLoad={() => setIsImageLoaded(true)}\n              />\n            ) : (\n              <div className=\"w-full h-full flex items-center justify-center text-3xl\">\n                <PlatformIcon />\n              </div>\n            )}\n          </div>\n\n          {/* Content */}\n          <div className=\"flex-1 min-w-0 flex flex-col justify-between\">\n            <div>\n              <div className=\"flex items-center gap-2 mb-1\">\n                {product.platform && (\n                  <span className=\"text-xs text-primary\">\n                    {getLocalizedValue(product.platform.name, product.platform.nameAr, locale)}\n                  </span>\n                )}\n                <DeliveryBadge />\n              </div>\n              <h3 className=\"font-semibold text-sm line-clamp-1 group-hover:text-primary transition-colors\">\n                {getLocalizedValue(product.name, product.nameAr, locale)}\n              </h3>\n            </div>\n\n            <div className=\"flex items-center justify-between\">\n              <PriceDisplay\n                price={product.price}\n                compareAtPrice={product.compareAtPrice}\n              />\n              {product.pointsReward > 0 && (\n                <span className=\"text-xs text-accent-amber flex items-center gap-0.5\">\n                  <Zap className=\"w-3 h-3\" />\n                  {product.pointsReward}\n                </span>\n              )}\n            </div>\n          </div>\n        </div>\n      </Link>\n    );\n  }\n\n  // Default / Featured Card\n  return (\n    <div\n      className=\"group\"\n      onMouseEnter={() => setShowQuickActions(true)}\n      onMouseLeave={() => setShowQuickActions(false)}\n    >\n      <Card className=\"card-glow h-full overflow-hidden border-border/50\">\n        <CardContent className=\"p-0\">\n          {/* Image Section */}\n          <div className=\"relative aspect-square bg-background-lighter overflow-hidden\">\n            {/* Product Image */}\n            <div className=\"relative z-10 w-full h-full flex items-center justify-center bg-card\">\n              {product.image ? (\n                <Image\n                  src={product.image}\n                  alt={getLocalizedValue(product.name, product.nameAr, locale)}\n                  fill\n                  sizes=\"(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw\"\n                  className={cn(\n                    'object-cover transition-transform duration-500 group-hover:scale-110',\n                    !isImageLoaded && 'opacity-0'\n                  )}\n                  onLoad={() => setIsImageLoaded(true)}\n                />\n              ) : (\n                <div className=\"text-7xl transition-transform duration-500 group-hover:scale-110\">\n                  <PlatformIcon />\n                </div>\n              )}\n            </div>\n\n            {/* Badges */}\n            <div className={cn(\n              'absolute top-3 z-20 flex flex-col gap-2',\n              isRTL ? 'left-3' : 'left-3'\n            )}>\n              {product.isNew && (\n                <Badge variant=\"new\" size=\"sm\" className=\"animate-pulse\">\n                  {locale === 'ar' ? 'ГҸВјГҸВ»в”ҳГЁГҸВ»' : 'NEW'}\n                </Badge>\n              )}\n              {discountPercent > 0 && (\n                <Badge variant=\"sale\" size=\"sm\">\n                  -{discountPercent}%\n                </Badge>\n              )}\n              {product.isFeatured && (\n                <Badge variant=\"featured\" size=\"sm\">\n                  {locale === 'ar' ? 'в”ҳГ в”ҳГ в”ҳГЁГҸв–“' : 'Featured'}\n                </Badge>\n              )}\n            </div>\n\n            {/* Quick Actions Overlay */}\n            <div\n              className={cn(\n                'absolute inset-0 z-20 bg-gradient-to-t from-background/90 via-background/50 to-transparent',\n                'transition-opacity duration-300',\n                showQuickActions ? 'opacity-100' : 'opacity-0'\n              )}\n            >\n              <div className={cn(\n                'absolute bottom-3 left-3 right-3 flex items-center justify-between',\n                isRTL && 'flex-row-reverse'\n              )}>\n                <div className=\"flex items-center gap-2\">\n                  <Button\n                    size=\"sm\"\n                    variant=\"primary\"\n                    onClick={(e) => {\n                      e.preventDefault();\n                      onAddToCart?.(product.id);\n                    }}\n                    className=\"btn-electric\"\n                  >\n                    <ShoppingCart className=\"w-4 h-4\" />\n                  </Button>\n                  <Button\n                    size=\"sm\"\n                    variant=\"secondary\"\n                    onClick={(e) => {\n                      e.preventDefault();\n                      onToggleWishlist?.(product.id);\n                    }}\n                    className={cn(\n                      'transition-colors',\n                      isWishlisted && 'bg-error hover:bg-error/80'\n                    )}\n                  >\n                    <Heart className={cn('w-4 h-4', isWishlisted && 'fill-current')} />\n                  </Button>\n                  <Button\n                    size=\"sm\"\n                    variant=\"secondary\"\n                    onClick={(e) => {\n                      e.preventDefault();\n                      onToggleCompare?.(product.id);\n                    }}\n                    className={cn(\n                      'transition-colors',\n                      isComparing && 'bg-accent-amber text-text-dark hover:bg-accent-orange'\n                    )}\n                  >\n                    <Scale className=\"w-4 h-4\" />\n                  </Button>\n                </div>\n                <Link href={`/${locale}/products/${product.slug}`}>\n                  <Button size=\"sm\" variant=\"outline\">\n                    <Eye className=\"w-4 h-4\" />\n                  </Button>\n                </Link>\n              </div>\n            </div>\n\n            {/* Platform Badge */}\n            <div\n              className={cn(\n                'absolute top-3 z-20',\n                isRTL ? 'right-3' : 'right-3'\n              )}\n            >\n              <div className=\"w-10 h-10 rounded-lg bg-background/80 backdrop-blur-sm flex items-center justify-center border border-border/50\">\n                <PlatformIcon />\n              </div>\n            </div>\n\n            {/* Rating Badge */}\n            {product.rating > 0 && (\n              <div\n                className={cn(\n                  'absolute bottom-3 z-10 flex items-center gap-1 px-2 py-1 rounded-lg',\n                  'bg-background/80 backdrop-blur-sm text-xs font-medium',\n                  showQuickActions ? 'opacity-0' : 'opacity-100',\n                  'transition-opacity duration-300',\n                  isRTL ? 'right-3' : 'left-3'\n                )}\n              >\n                <Star className=\"w-3 h-3 fill-accent-amber text-accent-amber\" />\n                <span>{product.rating.toFixed(1)}</span>\n                <span className=\"text-text-muted\">({product.ratingCount})</span>\n              </div>\n            )}\n          </div>\n\n          {/* Content Section */}\n          <div className=\"p-4\">\n            {/* Platform & Delivery */}\n            <div className=\"flex items-center justify-between mb-2\">\n              {product.platform && (\n                <span className=\"text-xs text-primary font-medium\">\n                  {getLocalizedValue(product.platform.name, product.platform.nameAr, locale)}\n                </span>\n              )}\n              <DeliveryBadge />\n            </div>\n\n            {/* Title */}\n            <Link href={`/${locale}/products/${product.slug}`}>\n              <h3 className=\"font-semibold mb-3 line-clamp-2 min-h-[2.5rem] group-hover:text-primary transition-colors\">\n                {getLocalizedValue(product.name, product.nameAr, locale)}\n              </h3>\n            </Link>\n\n            {/* Rating */}\n            <div className=\"mb-3\">\n              <RatingStars rating={product.rating} count={product.ratingCount} size=\"sm\" />\n            </div>\n\n            {/* Price & Actions */}\n            <div className=\"flex items-center justify-between\">\n              <div>\n                <PriceDisplay\n                  price={product.price}\n                  compareAtPrice={product.compareAtPrice}\n                />\n                {product.pointsReward > 0 && (\n                  <div className=\"flex items-center gap-1 mt-1 text-xs text-accent-amber\">\n                    <Zap className=\"w-3 h-3\" />\n                    <span>+{product.pointsReward} {locale === 'ar' ? 'в”ҳГҘв”ҳГ©ГҸГҖГҸВ®' : 'points'}</span>\n                  </div>\n                )}\n              </div>\n\n              <Link href={`/${locale}/products/${product.slug}`}>\n                <Button\n                  size=\"sm\"\n                  variant=\"primary\"\n                  className=\"btn-electric opacity-0 group-hover:opacity-100 transition-opacity\"\n                >\n                  {locale === 'ar' ? 'ГҸв•ЈГҸв–’ГҸГӮ' : 'View'}\n                </Button>\n              </Link>\n            </div>\n          </div>\n        </CardContent>\n      </Card>\n    </div>\n  );\n}\n\n// Export a hook for managing product comparisons\nexport function useProductComparison() {\n  const [compareList, setCompareList] = useState<string[]>([]);\n\n  const toggleCompare = (productId: string) => {\n    setCompareList((prev) =>\n      prev.includes(productId)\n        ? prev.filter((id) => id !== productId)\n        : prev.length < 4\n        ? [...prev, productId]\n        : prev\n    );\n  };\n\n  const isComparing = (productId: string) => compareList.includes(productId);\n\n  const clearCompare = () => setCompareList([]);\n\n  return { compareList, toggleCompare, isComparing, clearCompare };\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\USER\\Desktop\\RaadFun\\SSS\\ecom\\src\\components\\store\\product-comparison.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'index' is defined but never used.","line":92,"column":38,"nodeType":"Identifier","messageId":"unusedVar","endLine":92,"endColumn":43},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":272,"column":25,"nodeType":"JSXOpeningElement","endLine":276,"endColumn":27}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { useState, useEffect } from 'react';\r\nimport Link from 'next/link';\r\nimport { X, Scale, Check, AlertCircle, Star, ShoppingCart } from 'lucide-react';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport { Card, CardContent } from '@/components/ui/card';\r\nimport { cn } from '@/lib/utils';\r\n\r\ninterface Product {\r\n  id: string;\r\n  name: string;\r\n  nameAr: string;\r\n  slug: string;\r\n  price: number;\r\n  compareAtPrice?: number;\r\n  rating: number;\r\n  ratingCount: number;\r\n  platform: { name: string; nameAr: string; slug: string };\r\n  deliveryType?: string;\r\n  image?: string;\r\n  features?: string[];\r\n  description?: string;\r\n  descriptionAr?: string;\r\n}\r\n\r\ninterface ProductComparisonProps {\r\n  locale: string;\r\n  products: Product[];\r\n  onRemove: (productId: string) => void;\r\n  onClear: () => void;\r\n}\r\n\r\nexport function ProductComparison({\r\n  locale,\r\n  products,\r\n  onRemove,\r\n  onClear,\r\n}: ProductComparisonProps) {\r\n  const isRTL = locale === 'ar';\r\n\r\n  if (products.length === 0) {\r\n    return (\r\n      <div className=\"flex flex-col items-center justify-center py-20 text-center\">\r\n        <div className=\"w-24 h-24 rounded-full bg-background-lighter flex items-center justify-center mb-6\">\r\n          <Scale className=\"w-12 h-12 text-text-muted\" />\r\n        </div>\r\n        <h3 className=\"text-xl font-semibold mb-2\">\r\n          {locale === 'ar' ? 'в”ҳГӨГҸВә ГҸВ¬в”ҳГӘГҸВјГҸВ» в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ в”ҳГӨв”ҳГӨв”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ®' : 'No products to compare'}\r\n        </h3>\r\n        <p className=\"text-text-muted mb-6 max-w-md\">\r\n          {locale === 'ar'\r\n            ? 'ГҸГәГҸГӮв”ҳГј в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ ГҸГ‘в”ҳГӨв”ҳГ« в”ҳГ©ГҸВәГҸВӘв”ҳГ ГҸВ® ГҸВәв”ҳГӨв”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ® в”ҳГӨв”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ® ГҸВәв”ҳГӨв”ҳГ в”ҳГ в”ҳГЁГҸв–“ГҸВәГҸВ¬ в”ҳГӘГҸВәв”ҳГӨГҸГәГҸв”ӮГҸв•ЈГҸВәГҸв–’'\r\n            : 'Add products to the comparison list to compare features and prices'}\r\n        </p>\r\n        <Link href={`/${locale}/products`}>\r\n          <Button variant=\"primary\" className=\"btn-electric\">\r\n            {locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Browse Products'}\r\n          </Button>\r\n        </Link>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const getLocalizedValue = (en: string, ar: string) => (isRTL ? ar : en);\r\n\r\n  // Comparison categories\r\n  const comparisonSections = [\r\n    {\r\n      title: isRTL ? 'ГҸВәв”ҳГӨГҸв”ӮГҸв•ЈГҸв–’' : 'Price',\r\n      items: [\r\n        {\r\n          label: isRTL ? 'ГҸВәв”ҳГӨГҸв”ӮГҸв•ЈГҸв–’' : 'Price',\r\n          key: 'price',\r\n          render: (product: Product) => (\r\n            <div className=\"flex items-center gap-2\">\r\n              <span className=\"text-lg font-bold text-primary\">\r\n                ${product.price.toFixed(2)}\r\n              </span>\r\n              {product.compareAtPrice && (\r\n                <span className=\"text-sm text-text-muted line-through\">\r\n                  ${product.compareAtPrice.toFixed(2)}\r\n                </span>\r\n              )}\r\n            </div>\r\n          ),\r\n        },\r\n        {\r\n          label: isRTL ? 'в”ҳГ©в”ҳГЁв”ҳГ ГҸВ® ГҸГәв”ҳГјГҸГӮв”ҳГӨ ГҸв”ӮГҸв•ЈГҸв–’' : 'Best Value',\r\n          key: 'bestValue',\r\n          render: (product: Product, index: number) => {\r\n            const prices = products.map((p) => p.price);\r\n            const minPrice = Math.min(...prices);\r\n            const isBest = product.price === minPrice;\r\n            return isBest ? (\r\n              <Badge variant=\"success\" className=\"gap-1\">\r\n                <Check className=\"w-3 h-3\" />\r\n                {isRTL ? 'ГҸГәв”ҳГјГҸГӮв”ҳГӨ в”ҳГ©в”ҳГЁв”ҳГ ГҸВ®' : 'Best Value'}\r\n              </Badge>\r\n            ) : null;\r\n          },\r\n        },\r\n      ],\r\n    },\r\n    {\r\n      title: isRTL ? 'ГҸВәв”ҳГӨГҸВ¬в”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ ' : 'Rating',\r\n      items: [\r\n        {\r\n          label: isRTL ? 'ГҸВәв”ҳГӨГҸВ¬в”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ ' : 'Rating',\r\n          key: 'rating',\r\n          render: (product: Product) => (\r\n            <div className=\"flex items-center gap-2\">\r\n              <div className=\"flex items-center gap-0.5\">\r\n                {[...Array(5)].map((_, i) => (\r\n                  <Star\r\n                    key={i}\r\n                    className={cn(\r\n                      'w-4 h-4',\r\n                      i < Math.floor(product.rating)\r\n                        ? 'fill-accent-amber text-accent-amber'\r\n                        : 'fill-transparent text-text-muted'\r\n                    )}\r\n                  />\r\n                ))}\r\n              </div>\r\n              <span className=\"font-medium\">{product.rating.toFixed(1)}</span>\r\n              <span className=\"text-text-muted text-sm\">\r\n                ({product.ratingCount})\r\n              </span>\r\n            </div>\r\n          ),\r\n        },\r\n        {\r\n          label: isRTL ? 'ГҸВәв”ҳГӨГҸГәГҸв•Јв”ҳГӨв”ҳГ« ГҸВ¬в”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ ГҸВәв”ҳГҜ' : 'Top Rated',\r\n          key: 'topRated',\r\n          render: (product: Product) => {\r\n            const ratings = products.map((p) => p.rating);\r\n            const maxRating = Math.max(...ratings);\r\n            const isTop = product.rating === maxRating;\r\n            return isTop && product.rating > 0 ? (\r\n              <Badge variant=\"success\" className=\"gap-1\">\r\n                <Check className=\"w-3 h-3\" />\r\n                {isRTL ? 'ГҸВәв”ҳГӨГҸГәГҸв•Јв”ҳГӨв”ҳГ« ГҸВ¬в”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ ГҸВәв”ҳГҜ' : 'Top Rated'}\r\n              </Badge>\r\n            ) : null;\r\n          },\r\n        },\r\n      ],\r\n    },\r\n    {\r\n      title: isRTL ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВ®' : 'Platform',\r\n      items: [\r\n        {\r\n          label: isRTL ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВ®' : 'Platform',\r\n          key: 'platform',\r\n          render: (product: Product) => (\r\n            <Badge variant=\"outline\" className=\"text-sm\">\r\n              {getLocalizedValue(product.platform.name, product.platform.nameAr)}\r\n            </Badge>\r\n          ),\r\n        },\r\n        {\r\n          label: isRTL ? 'ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӨв”ҳГЁв”ҳГ ' : 'Delivery',\r\n          key: 'delivery',\r\n          render: (product: Product) => {\r\n            const deliveryLabels = {\r\n              auto_key: isRTL ? 'в”ҳГ в”ҳГјГҸВ¬ГҸВәГҸВЎ ГҸВ¬в”ҳГӨв”ҳГ©ГҸВәГҸВӘв”ҳГЁ' : 'Auto Key',\r\n              auto_account: isRTL ? 'ГҸВЎГҸв”ӮГҸВәГҸВҝ ГҸВ¬в”ҳГӨв”ҳГ©ГҸВәГҸВӘв”ҳГЁ' : 'Auto Account',\r\n              manual: isRTL ? 'в”ҳГЁГҸВ»в”ҳГӘв”ҳГЁ' : 'Manual',\r\n              contact: isRTL ? 'ГҸВ¬в”ҳГӘГҸВәГҸГҒв”ҳГӨ' : 'Contact',\r\n            };\r\n            const label = product.deliveryType\r\n              ? deliveryLabels[product.deliveryType as keyof typeof deliveryLabels]\r\n              : '-';\r\n            return <span className=\"text-sm\">{label}</span>;\r\n          },\r\n        },\r\n      ],\r\n    },\r\n    {\r\n      title: isRTL ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГ в”ҳГЁГҸв–“ГҸВәГҸВ¬' : 'Features',\r\n      items: [\r\n        {\r\n          label: isRTL ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГ в”ҳГЁГҸв–“ГҸВәГҸВ¬' : 'Features',\r\n          key: 'features',\r\n          render: (product: Product) => (\r\n            <ul className=\"space-y-2 text-sm\">\r\n              {product.features?.slice(0, 4).map((feature, index) => (\r\n                <li key={index} className=\"flex items-start gap-2\">\r\n                  <Check className=\"w-4 h-4 text-success shrink-0 mt-0.5\" />\r\n                  <span className=\"text-text-muted-light\">{feature}</span>\r\n                </li>\r\n              )) || <span className=\"text-text-muted\">-</span>}\r\n            </ul>\r\n          ),\r\n        },\r\n      ],\r\n    },\r\n  ];\r\n\r\n  return (\r\n    <div className=\"space-y-6\">\r\n      {/* Header */}\r\n      <div className=\"flex items-center justify-between\">\r\n        <div>\r\n          <h2 className=\"text-2xl font-bold mb-1\">\r\n            {locale === 'ar' ? 'в”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ® ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Product Comparison'}\r\n          </h2>\r\n          <p className=\"text-text-muted\">\r\n            {locale === 'ar'\r\n              ? `в”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ® ${products.length} в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬`\r\n              : `Comparing ${products.length} product${products.length > 1 ? 's' : ''}`}\r\n          </p>\r\n        </div>\r\n        <Button variant=\"ghost\" onClick={onClear}>\r\n          <X className=\"w-4 h-4 mr-2\" />\r\n          {locale === 'ar' ? 'в”ҳГ ГҸв”ӮГҸВЎ ГҸВәв”ҳГӨв”ҳГўв”ҳГӨ' : 'Clear All'}\r\n        </Button>\r\n      </div>\r\n\r\n      {/* Add More Prompt */}\r\n      {products.length < 4 && (\r\n        <Card className=\"border-dashed border-2 border-border/50 bg-transparent\">\r\n          <CardContent className=\"p-4\">\r\n            <div className=\"flex items-center justify-center gap-4\">\r\n              <AlertCircle className=\"w-5 h-5 text-accent-amber\" />\r\n              <p className=\"text-text-muted\">\r\n                {locale === 'ar'\r\n                  ? `в”ҳГЁв”ҳГ в”ҳГўв”ҳГҘв”ҳГў ГҸГ‘ГҸГӮГҸВәв”ҳГјГҸВ® ${4 - products.length} в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ ГҸГәГҸВ«ГҸв–’в”ҳГ« в”ҳГӨв”ҳГӨв”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ®`\r\n                  : `You can add ${4 - products.length} more product${4 - products.length > 1 ? 's' : ''} to compare`}\r\n              </p>\r\n              <Link href={`/${locale}/products`}>\r\n                <Button variant=\"outline\" size=\"sm\">\r\n                  {locale === 'ar' ? 'ГҸГ‘ГҸГӮГҸВәв”ҳГјГҸВ® в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Add Products'}\r\n                </Button>\r\n              </Link>\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {/* Comparison Table */}\r\n      <div className=\"overflow-x-auto custom-scrollbar\">\r\n        <div className=\"min-w-[800px]\">\r\n          {/* Product Headers */}\r\n          <div className=\"grid grid-cols-5 gap-4 mb-6\">\r\n            {/* Label Column */}\r\n            <div className=\"font-semibold text-text-muted\">\r\n              {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГӘГҸВәГҸГҒв”ҳГјГҸВ®' : 'Specification'}\r\n            </div>\r\n\r\n            {/* Product Columns */}\r\n            {products.map((product) => (\r\n              <div key={product.id} className=\"relative\">\r\n                <Card className=\"border-border/50\">\r\n                  <CardContent className=\"p-4\">\r\n                    {/* Remove Button */}\r\n                    <button\r\n                      onClick={() => onRemove(product.id)}\r\n                      className=\"absolute top-2 right-2 p-1.5 rounded-lg bg-background hover:bg-error hover:text-white transition-colors\"\r\n                    >\r\n                      <X className=\"w-4 h-4\" />\r\n                    </button>\r\n\r\n                    {/* Product Image */}\r\n                    <Link\r\n                      href={`/${locale}/products/${product.slug}`}\r\n                      className=\"block aspect-square bg-background-lighter rounded-lg overflow-hidden mb-3\"\r\n                    >\r\n                      {product.image ? (\r\n                        <img\r\n                          src={product.image}\r\n                          alt={getLocalizedValue(product.name, product.nameAr)}\r\n                          className=\"w-full h-full object-cover\"\r\n                        />\r\n                      ) : (\r\n                        <div className=\"w-full h-full flex items-center justify-center text-4xl\">\r\n                          ВӯЖ’Г„В«\r\n                        </div>\r\n                      )}\r\n                    </Link>\r\n\r\n                    {/* Product Name */}\r\n                    <Link\r\n                      href={`/${locale}/products/${product.slug}`}\r\n                      className=\"block font-semibold hover:text-primary transition-colors line-clamp-2 mb-2\"\r\n                    >\r\n                      {getLocalizedValue(product.name, product.nameAr)}\r\n                    </Link>\r\n\r\n                    {/* Platform Badge */}\r\n                    <Badge variant=\"outline\" size=\"sm\" className=\"mb-3\">\r\n                      {getLocalizedValue(product.platform.name, product.platform.nameAr)}\r\n                    </Badge>\r\n\r\n                    {/* Add to Cart Button */}\r\n                    <Button variant=\"primary\" size=\"sm\" className=\"w-full btn-electric\">\r\n                      <ShoppingCart className=\"w-4 h-4 mr-2\" />\r\n                      {locale === 'ar' ? 'ГҸГәГҸГӮв”ҳГј в”ҳГӨв”ҳГӨГҸв”Ӯв”ҳГӨГҸВ®' : 'Add to Cart'}\r\n                    </Button>\r\n                  </CardContent>\r\n                </Card>\r\n              </div>\r\n            ))}\r\n          </div>\r\n\r\n          {/* Comparison Sections */}\r\n          {comparisonSections.map((section) => (\r\n            <div key={section.title} className=\"mb-6\">\r\n              <h3 className=\"text-sm font-semibold text-text-muted uppercase tracking-wider mb-3\">\r\n                {section.title}\r\n              </h3>\r\n              <Card className=\"border-border/50\">\r\n                <CardContent className=\"p-0\">\r\n                  {section.items.map((item, itemIndex) => (\r\n                    <div\r\n                      key={item.key}\r\n                      className={cn(\r\n                        'grid grid-cols-5 gap-4 p-4',\r\n                        itemIndex > 0 && 'border-t border-border/50'\r\n                      )}\r\n                    >\r\n                      {/* Label */}\r\n                      <div className=\"font-medium text-text-muted\">\r\n                        {item.label}\r\n                      </div>\r\n\r\n                      {/* Values */}\r\n                      {products.map((product) => (\r\n                        <div key={product.id} className=\"flex items-center\">\r\n                          {item.render(product, products.indexOf(product))}\r\n                        </div>\r\n                      ))}\r\n                    </div>\r\n                  ))}\r\n                </CardContent>\r\n              </Card>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\n// Comparison Bar - Fixed bottom bar when products are selected\r\nexport function ComparisonBar({\r\n  count,\r\n  locale,\r\n  onOpen,\r\n  onClear,\r\n}: {\r\n  count: number;\r\n  locale: string;\r\n  onOpen: () => void;\r\n  onClear: () => void;\r\n}) {\r\n  const [isVisible, setIsVisible] = useState(true);\r\n\r\n  useEffect(() => {\r\n    setIsVisible(count > 0);\r\n  }, [count]);\r\n\r\n  if (!isVisible || count === 0) return null;\r\n\r\n  return (\r\n    <div className=\"fixed bottom-0 left-0 right-0 z-50 animate-slide-up\">\r\n      <div className=\"container mx-auto px-4 pb-4\">\r\n        <Card className=\"shadow-glow border-primary/50\">\r\n          <CardContent className=\"p-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <div className=\"flex items-center gap-4\">\r\n                <div className=\"w-10 h-10 rounded-lg bg-accent-amber/20 flex items-center justify-center\">\r\n                  <Scale className=\"w-5 h-5 text-accent-amber\" />\r\n                </div>\r\n                <div>\r\n                  <p className=\"font-semibold\">\r\n                    {locale === 'ar'\r\n                      ? `${count} в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ в”ҳГӨв”ҳГӨв”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ®`\r\n                      : `${count} product${count > 1 ? 's' : ''} to compare`}\r\n                  </p>\r\n                  <p className=\"text-sm text-text-muted\">\r\n                    {locale === 'ar'\r\n                      ? 'ГҸВәГҸГӮГҸв•‘ГҸГҖ в”ҳГӨв”ҳГӨв”ҳГ в”ҳГ©ГҸВәГҸв–’в”ҳГҘГҸВ® ГҸВҝв”ҳГЁв”ҳГҘ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬'\r\n                      : 'Click to compare products'}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n\r\n              <div className=\"flex items-center gap-3\">\r\n                <Button variant=\"ghost\" onClick={onClear}>\r\n                  {locale === 'ar' ? 'в”ҳГ ГҸв”ӮГҸВЎ' : 'Clear'}\r\n                </Button>\r\n                <Button variant=\"primary\" onClick={onOpen} className=\"btn-electric\">\r\n                  {locale === 'ar' ? 'в”ҳГ©ГҸВәГҸв–’в”ҳГҘ ГҸВәв”ҳГӨГҸГів”ҳГҘ' : 'Compare Now'}\r\n                </Button>\r\n              </div>\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\USER\\Desktop\\RaadFun\\SSS\\ecom\\src\\components\\ui\\avatar.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\USER\\Desktop\\RaadFun\\SSS\\ecom\\src\\components\\ui\\badge.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\USER\\Desktop\\RaadFun\\SSS\\ecom\\src\\components\\ui\\button.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCou