ded-full\">\n              <Sparkles className=\"w-4 h-4\" />\n              {locale === 'ar' ? 'в”ҳГӘГҸГҒв”ҳГӘв”ҳГӨ ГҸВјГҸВ»в”ҳГЁГҸВ» в”ҳГўв”ҳГӨ в”ҳГЁв”ҳГӘв”ҳГ ' : 'New arrivals every day'}\n            </Badge>\n          </div>\n\n          {/* Heading */}\n          <h1 className=\"animate-slide-up text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6\">\n            <span className=\"text-text\">\n              {locale === 'ar' ? 'ГҸГәв”ҳГјГҸГӮв”ҳГӨ в”ҳГ в”ҳГҘГҸГҒГҸВ®' : 'The Premier Platform '}\n              <br className=\"hidden md:block\" />\n            </span>\n            <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-primary-light to-primary-lighter\">\n              {locale === 'ar' ? 'в”ҳГӨв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ ГҸВәв”ҳГӨГҸв–’в”ҳГ©в”ҳГ в”ҳГЁГҸВ®' : 'for Digital Products'}\n            </span>\n          </h1>\n\n          {/* Subheading */}\n          <p className=\"animate-slide-up delay-100 text-lg md:text-xl text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed\">\n            {locale === 'ar'\n              ? 'в”ҳГ©в”ҳГ  ГҸВҝГҸВ¬в”ҳГӘГҸв”Ӯв”ҳГЁГҸв•Ј в”ҳГҘГҸГҖГҸВәв”ҳГ© ГҸГәГҸв•Јв”ҳГ ГҸВәв”ҳГӨв”ҳГў в”ҳГӘГҸГ‘в”ҳГҘГҸВ¬ГҸВәГҸВјв”ҳГЁГҸВ¬в”ҳГў в”ҳГ ГҸв•Ј в”ҳГ ГҸВјв”ҳГ в”ҳГӘГҸв•ЈГҸВ¬в”ҳГҘГҸВә ГҸВәв”ҳГӨв”ҳГӘГҸВәГҸв”ӮГҸв•ЈГҸВ® в”ҳГ в”ҳГҘ ГҸВәв”ҳГӨГҸВәГҸв”ӨГҸВ¬ГҸв–’ГҸВәв”ҳГўГҸВәГҸВ¬ в”ҳГӘГҸВәв”ҳГӨГҸВҝГҸв–’в”ҳГ ГҸВјв”ҳГЁГҸВәГҸВ¬ в”ҳГӘГҸВәв”ҳГӨв”ҳГ ГҸв–“в”ҳГЁГҸВ».'\n              : 'Scale your business and productivity with our curated collection of enterprise subscriptions, software, and APIs.'}\n          </p>\n\n          {/* CTA Buttons */}\n          <div className=\"animate-slide-up delay-200 flex flex-col sm:flex-row items-center justify-center gap-4 mb-16\">\n            <Link href={`/${locale}/products`}>\n              <Button size=\"lg\" className=\"w-full sm:w-auto px-8 bg-primary hover:bg-primary-hover text-white shadow-lg shadow-primary/20 gap-2 rounded-full transition-all hover:scale-105\">\n                {locale === 'ar' ? 'ГҸВәГҸв”ӮГҸВ¬в”ҳГўГҸв”Өв”ҳГј ГҸВәв”ҳГӨв”ҳГўГҸВ¬ГҸВәв”ҳГӨв”ҳГӘГҸВј' : 'Explore Catalog'}\n                <ArrowRight className={cn('w-4 h-4', isRTL && 'rotate-180')} />\n              </Button>\n            </Link>\n            <Link href={`/${locale}/platforms`}>\n              <Button size=\"lg\" variant=\"outline\" className=\"w-full sm:w-auto px-8 gap-2 rounded-full bg-background/50 backdrop-blur-sm border-border hover:bg-card\">\n                {locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВәГҸВ¬' : 'View Platforms'}\n              </Button>\n            </Link>\n          </div>\n\n          {/* B2B SaaS Dashboard Mockup / Hero Image Placeholder */}\n          <div className=\"animate-slide-up delay-300 relative mx-auto w-full max-w-5xl rounded-2xl border border-white/10 bg-card/40 backdrop-blur-xl shadow-2xl overflow-hidden mt-10\">\n            {/* Mockup Header */}\n            <div className=\"h-10 border-b border-white/10 flex items-center px-4 gap-2 bg-gradient-to-r from-background-light to-background\">\n              <div className=\"w-3 h-3 rounded-full bg-red-500/80\" />\n              <div className=\"w-3 h-3 rounded-full bg-amber-500/80\" />\n              <div className=\"w-3 h-3 rounded-full bg-green-500/80\" />\n            </div>\n            {/* Mockup Body Content */}\n            <div className=\"p-8 aspect-[16/9] md:aspect-[21/9] flex items-center justify-center bg-gradient-to-br from-card to-background-light\">\n              <div className=\"text-center space-y-4\">\n                <div className=\"mx-auto w-16 h-16 rounded-xl bg-primary/10 flex items-center justify-center mb-4\">\n                  <Flame className=\"w-8 h-8 text-primary\" />\n                </div>\n                <h3 className=\"text-xl md:text-2xl font-semibold opacity-90\">\n                  {locale === 'ar' ? 'в”ҳГӨв”ҳГӘГҸВЎГҸВ® ГҸВ¬ГҸВЎв”ҳГўв”ҳГ  ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Enterprise Product Dashboard'}\n                </h3>\n                <p className=\"text-text-muted max-w-md mx-auto\">\n                  {locale === 'ar' ? 'в”ҳГӘГҸВәГҸВјв”ҳГ§ГҸВ® в”ҳГ ГҸв”ӮГҸВ¬ГҸВ«ГҸВ»в”ҳГ  ГҸВЎГҸВ»в”ҳГЁГҸВҪГҸВ® в”ҳГӨГҸГ‘ГҸВ»ГҸВәГҸв–’ГҸВ® ГҸВјв”ҳГ в”ҳГЁГҸв•Ј ГҸГәГҸГҒв”ҳГӘв”ҳГӨв”ҳГў ГҸВәв”ҳГӨГҸв–’в”ҳГ©в”ҳГ в”ҳГЁГҸВ®' : 'A modern interface to manage and browse your complete digital inventory'}\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* SaaS Feature Bento Grid */}\n      <section className=\"relative z-20 py-16 bg-background\">\n        <div className=\"container mx-auto px-4 max-w-6xl\">\n          <div className=\"mb-12 text-center md:text-left\">\n            <Badge variant=\"outline\" className=\"mb-4 shadow-sm backdrop-blur-sm\">\n              <Shield className=\"w-4 h-4 mr-2 text-primary\" />\n              {locale === 'ar' ? 'в”ҳГ в”ҳГ в”ҳГЁГҸв–“ГҸВәГҸВ¬ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВ®' : 'Platform Features'}\n            </Badge>\n            <h2 className=\"text-3xl md:text-4xl font-bold\">\n              {locale === 'ar' ? 'в”ҳГ ГҸГҒв”ҳГ в”ҳГ  в”ҳГӨв”ҳГӨГҸв”ӮГҸв–’ГҸв•ЈГҸВ® в”ҳГӘГҸВәв”ҳГӨв”ҳГ в”ҳГӘГҸВҪв”ҳГӘв”ҳГ©в”ҳГЁГҸВ®' : 'Engineered for Speed & Reliability'}\n            </h2>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n            {/* Large Feature Block */}\n            <Card className=\"md:col-span-2 group relative overflow-hidden bg-card/50 border-white/5 hover:border-primary/30 transition-all duration-500\">\n              <div className=\"absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n              <CardContent className=\"p-8 h-full flex flex-col justify-between relative z-10\">\n                <div className=\"w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6\">\n                  <Zap className=\"w-6 h-6 text-primary\" />\n                </div>\n                <div>\n                  <h3 className=\"text-2xl font-semibold mb-2\">\n                    {locale === 'ar' ? 'ГҸВ¬в”ҳГӘГҸГҒв”ҳГЁв”ҳГӨ в”ҳГјв”ҳГӘГҸв–’в”ҳГЁ в”ҳГӘв”ҳГ ГҸВ»в”ҳГјв”ҳГӘГҸв•ЈГҸВәГҸВ¬ ГҸГів”ҳГ в”ҳГҘГҸВ®' : 'Instant Delivery & Secure Payments'}\n                  </h3>\n                  <p className=\"text-text-muted\">\n                    {locale === 'ar'\n                      ? 'в”ҳГӨГҸВә ГҸВ»ГҸВәГҸв•Јв”ҳГЁ в”ҳГӨв”ҳГӨГҸВәв”ҳГҘГҸВ¬ГҸВ©ГҸВәГҸв–’. ГҸВәГҸВЎГҸГҒв”ҳГӨ ГҸв•Јв”ҳГӨв”ҳГ« в”ҳГ в”ҳГјГҸВәГҸВ¬в”ҳГЁГҸВЎ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ в”ҳГӘГҸВәв”ҳГӨГҸВәГҸв”ӨГҸВ¬ГҸв–’ГҸВәв”ҳГўГҸВәГҸВ¬ в”ҳГјв”ҳГӘГҸв–’ГҸВәв”ҳГҜ ГҸВҝГҸв•ЈГҸВ» ГҸГ‘ГҸВ¬в”ҳГ ГҸВәв”ҳГ  ГҸВәв”ҳГӨГҸВ»в”ҳГјГҸв•Ј.'\n                      : 'Zero waiting time. Receive your product keys and subscription credentials instantly upon payment confirmation.'}\n                  </p>\n                </div>\n              </CardContent>\n            </Card>\n\n            {/* Small Feature Block 1 */}\n            <Card className=\"group relative overflow-hidden bg-card/50 border-white/5 hover:border-accent-amber/30 transition-all duration-500\">\n              <div className=\"absolute inset-0 bg-gradient-to-br from-accent-amber/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n              <CardContent className=\"p-8 h-full flex flex-col justify-between relative z-10\">\n                <div className=\"w-12 h-12 rounded-lg bg-accent-amber/10 flex items-center justify-center mb-6\">\n                  <Clock className=\"w-6 h-6 text-accent-amber\" />\n                </div>\n                <div>\n                  <h3 className=\"text-xl font-semibold mb-2\">\n                    {locale === 'ar' ? 'ГҸВ»ГҸв•Јв”ҳГ  24/7' : '24/7 Support'}\n                  </h3>\n                  <p className=\"text-sm text-text-muted\">\n                    {locale === 'ar'\n                      ? 'в”ҳГјГҸв–’в”ҳГЁв”ҳГ© в”ҳГ ГҸВ¬ГҸВ«ГҸГҒГҸГҒ в”ҳГ ГҸВ¬ГҸВәГҸВЎ ГҸВ»ГҸВәГҸВӘв”ҳГ ГҸВәв”ҳГҜ'\n                      : 'Dedicated team always available'}\n                  </p>\n                </div>\n              </CardContent>\n            </Card>\n\n            {/* Categories Bento (combines features + categories visually) */}\n            {CATEGORIES.slice(0, 3).map((category, index) => (\n              <Link key={category.slug} href={`/${locale}/products?category=${category.slug}`} className=\"block\">\n                <Card className={cn(\n                  \"group relative overflow-hidden transition-all duration-500 hover:-translate-y-1 h-full\",\n                  index === 0 ? \"bg-blue-900/10 hover:border-blue-500/30\" :\n                  index === 1 ? \"bg-purple-900/10 hover:border-purple-500/30\" :\n                  \"bg-amber-900/10 hover:border-amber-500/30\"\n                )}>\n                  <CardContent className=\"p-6\">\n                    <div className=\"flex justify-between items-start mb-4\">\n                      <span className=\"text-3xl\">{category.icon}</span>\n                      <Badge variant=\"outline\" className=\"bg-background/50 border-background/20\">\n                        {category.itemCount}+\n                      </Badge>\n                    </div>\n                    <h4 className=\"font-semibold text-lg mb-1\">{isRTL ? category.nameAr : category.name}</h4>\n                    <p className=\"text-sm text-text-muted\">\n                      {locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВәв”ҳГӨв”ҳГўГҸВ¬ГҸВәв”ҳГӨв”ҳГӘГҸВј' : 'Browse Catalog'}\n                    </p>\n                  </CardContent>\n                </Card>\n              </Link>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* Featured Products */}\n      <section className=\"py-20 bg-background-light\">\n        <div className=\"container mx-auto px-4\">\n          <div className=\"flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4\">\n            <div>\n              <Badge variant=\"new\" className=\"mb-4\">\n                <Flame className=\"w-4 h-4 mr-1\" />\n                {locale === 'ar' ? 'в”ҳГ в”ҳГ в”ҳГЁГҸв–“' : 'Featured'}\n              </Badge>\n              <h2 className=\"text-3xl md:text-4xl font-bold mb-2\">\n                {locale === 'ar' ? 'в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ в”ҳГ в”ҳГ в”ҳГЁГҸв–“ГҸВ®' : 'Featured Products'}\n              </h2>\n              <p className=\"text-text-muted max-w-xl\">\n                {locale === 'ar'\n                  ? 'ГҸВәГҸВ«ГҸВ¬в”ҳГЁГҸВәГҸв–’ГҸВәГҸВ¬в”ҳГҘГҸВә в”ҳГӨГҸГәв”ҳГјГҸГӮв”ҳГӨ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ в”ҳГ§ГҸв–‘ГҸВә ГҸВәв”ҳГӨГҸГәГҸв”ӮГҸВҝв”ҳГӘГҸв•Ј'\n                  : 'Our top picks for this week'}\n              </p>\n            </div>\n            <Link href={`/${locale}/products?featured=true`}>\n              <Button variant=\"outline\" className=\"gap-2\">\n                {locale === 'ar' ? 'ГҸв•ЈГҸв–’ГҸГӮ ГҸВәв”ҳГӨв”ҳГўв”ҳГӨ' : 'View All'}\n                <ArrowRight className={cn('w-4 h-4', isRTL && 'rotate-180')} />\n              </Button>\n            </Link>\n          </div>\n\n          <FeaturedProducts locale={locale} limit={4} featured={true} />\n        </div>\n      </section>\n\n      {/* Browse by Platform */}\n      <section className=\"py-20\">\n        <div className=\"container mx-auto px-4\">\n          <div className=\"text-center mb-12\">\n            <Badge variant=\"outline\" className=\"mb-4\">\n              {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВәГҸВ¬' : 'Platforms'}\n            </Badge>\n            <h2 className=\"text-3xl md:text-4xl font-bold mb-4\">\n              {locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВЎГҸв”ӮГҸВҝ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВ®' : 'Browse by Platform'}\n            </h2>\n            <p className=\"text-text-muted max-w-2xl mx-auto\">\n              {locale === 'ar'\n                ? 'ГҸВәГҸВ«ГҸВ¬ГҸв–’ в”ҳГ в”ҳГҘГҸГҒГҸВ¬в”ҳГў ГҸВәв”ҳГӨв”ҳГ в”ҳГјГҸГӮв”ҳГӨГҸВ® в”ҳГӘГҸВәв”ҳГўГҸВ¬ГҸв”Өв”ҳГј в”ҳГ ГҸВјв”ҳГ в”ҳГӘГҸв•ЈГҸВ® в”ҳГӘГҸВәГҸв”ӮГҸв•ЈГҸВ® в”ҳГ в”ҳГҘ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ ГҸВәв”ҳГӨГҸв–’в”ҳГ©в”ҳГ в”ҳГЁГҸВ®'\n                : 'Choose your favorite platform and discover a wide range of digital products'}\n            </p>\n          </div>\n\n          <PlatformsList locale={locale} limit={6} />\n\n          <div className=\"text-center mt-12\">\n            <Link href={`/${locale}/platforms`}>\n              <Button variant=\"outline\" size=\"lg\" className=\"gap-2\">\n                {locale === 'ar' ? 'ГҸв•ЈГҸв–’ГҸГӮ ГҸВјв”ҳГ в”ҳГЁГҸв•Ј ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВәГҸВ¬' : 'View All Platforms'}\n                <ArrowRight className={cn('w-5 h-5', isRTL && 'rotate-180')} />\n              </Button>\n            </Link>\n          </div>\n        </div>\n      </section>\n\n      {/* Special Offers Banner */}\n      <section className=\"py-24 bg-background\">\n        <div className=\"container mx-auto px-4 max-w-6xl\">\n          <div className=\"relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary/10 to-transparent border border-primary/20\">\n            {/* Decorative Elements */}\n            <div className=\"absolute top-0 right-0 w-96 h-96 bg-primary/20 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2\" />\n            \n            {/* Content */}\n            <div className=\"relative z-10 px-8 py-16 md:py-20 md:px-16 flex flex-col md:flex-row items-center justify-between gap-12\">\n              <div className=\"text-center md:text-left max-w-2xl\">\n                <Badge variant=\"outline\" className=\"mb-6 bg-primary/5 text-primary border-primary/20 font-medium\">\n                  <TrendingUp className=\"w-4 h-4 mr-2 inline\" />\n                  {locale === 'ar' ? 'ГҸв•ЈГҸв–’ГҸГӮ в”ҳГ ГҸВЎГҸВ»в”ҳГӘГҸВ» в”ҳГӨв”ҳГӨв”ҳГ ГҸГұГҸв”ӮГҸв”ӮГҸВәГҸВ¬' : 'Limited Enterprise Offer'}\n                </Badge>\n\n                <h2 className=\"text-3xl md:text-5xl font-bold mb-6 tracking-tight\">\n  