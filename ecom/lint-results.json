   ],\n    trending: [],\n  };\n};\n\nconst TRENDING_SEARCHES = [\n  { text: 'Elden Ring', slug: 'elden-ring' },\n  { text: 'GTA 5', slug: 'gta-5' },\n  { text: 'Netflix Premium', slug: 'netflix-premium' },\n  { text: 'PlayStation Plus', slug: 'playstation-plus' },\n  { text: 'ChatGPT Plus', slug: 'chatgpt-plus' },\n];\n\nconst RECENT_SEARCHES = [\n  { text: 'Cyberpunk 2077', slug: 'cyberpunk-2077' },\n  { text: 'Steam Gift Card', slug: 'steam-gift-card' },\n];\n\nexport async function generateMetadata({ params }: SearchPageProps): Promise<Metadata> {\n  const { locale } = await params;\n  return {\n    title: locale === 'ar' ? 'ГҸВҝГҸВЎГҸВҪ' : 'Search',\n  };\n};\n\nexport default async function SearchPage({ params, searchParams }: SearchPageProps) {\n  const { locale } = await params;\n  const search = await searchParams;\n  const query = search.q || '';\n  const isRTL = locale === 'ar';\n\n  const { results, suggestions, trending } = performSearch(query);\n\n  return (\n    <div className=\"min-h-screen py-8\">\n      <div className=\"container mx-auto px-4\">\n        {/* Search Header */}\n        <div className=\"mb-8\">\n          <div className=\"max-w-2xl mx-auto\">\n            <div className=\"relative\">\n              <SearchIcon className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted\" />\n              <Input\n                type=\"text\"\n                defaultValue={query}\n                placeholder={locale === 'ar' ? 'ГҸВәГҸВҝГҸВЎГҸВҪ ГҸв•Јв”ҳГҘ в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬...' : 'Search for products...'}\n                className=\"pl-12 h-14 text-lg\"\n                name=\"q\"\n              />\n              <Button\n                type=\"submit\"\n                size=\"lg\"\n                className=\"absolute right-2 top-1/2 -translate-y-1/2\"\n              >\n                {locale === 'ar' ? 'ГҸВҝГҸВЎГҸВҪ' : 'Search'}\n              </Button>\n            </div>\n\n            {/* Search Filters */}\n            <div className=\"flex flex-wrap gap-2 mt-4\">\n              <Button variant=\"outline\" size=\"sm\">\n                {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГўв”ҳГӨ' : 'All'}\n              </Button>\n              <Button variant=\"ghost\" size=\"sm\">\n                {locale === 'ar' ? 'ГҸГәв”ҳГӨГҸв•ЈГҸВәГҸВҝ' : 'Games'}\n              </Button>\n              <Button variant=\"ghost\" size=\"sm\">\n                {locale === 'ar' ? 'ГҸВәГҸв”ӨГҸВ¬ГҸв–’ГҸВәв”ҳГўГҸВәГҸВ¬' : 'Subscriptions'}\n              </Button>\n              <Button variant=\"ghost\" size=\"sm\">\n                Steam\n              </Button>\n              <Button variant=\"ghost\" size=\"sm\">\n                {locale === 'ar' ? 'ГҸв–‘в”ҳГўГҸВәГҸГӯ ГҸВәГҸГҒГҸГҖв”ҳГҘГҸВәГҸв•Јв”ҳГЁ' : 'AI'}\n              </Button>\n            </div>\n          </div>\n        </div>\n\n        {/* No Query - Show Suggestions */}\n        {!query && (\n          <div className=\"max-w-2xl mx-auto\">\n            {/* Recent Searches */}\n            {RECENT_SEARCHES.length > 0 && (\n              <Card className=\"mb-6\">\n                <CardContent className=\"p-6\">\n                  <div className=\"flex items-center gap-2 mb-4\">\n                    <Clock className=\"w-5 h-5 text-text-muted\" />\n                    <h3 className=\"font-semibold\">\n                      {locale === 'ar' ? 'ГҸв•Јв”ҳГ в”ҳГӨв”ҳГЁГҸВәГҸВ¬ ГҸВәв”ҳГӨГҸВҝГҸВЎГҸВҪ ГҸВәв”ҳГӨГҸГәГҸВ«в”ҳГЁГҸв–’ГҸВ®' : 'Recent Searches'}\n                    </h3>\n                  </div>\n                  <div className=\"flex flex-wrap gap-2\">\n                    {RECENT_SEARCHES.map((item) => (\n                      <Link\n                        key={item.slug}\n                        href={`/${locale}/search?q=${encodeURIComponent(item.text)}`}\n                      >\n                        <Badge variant=\"outline\" className=\"hover:bg-background-lighter cursor-pointer\">\n                          {item.text}\n                          <button className=\"ml-2 hover:text-error\">в”ңГ№</button>\n                        </Badge>\n                      </Link>\n                    ))}\n                  </div>\n                </CardContent>\n              </Card>\n            )}\n\n            {/* Trending Searches */}\n            <Card>\n              <CardContent className=\"p-6\">\n                <div className=\"flex items-center gap-2 mb-4\">\n                  <TrendingUp className=\"w-5 h-5 text-accent-orange\" />\n                  <h3 className=\"font-semibold\">\n                    {locale === 'ar' ? 'ГҸв•Јв”ҳГ в”ҳГӨв”ҳГЁГҸВәГҸВ¬ ГҸВәв”ҳГӨГҸВҝГҸВЎГҸВҪ ГҸВәв”ҳГӨГҸв–’ГҸВәГҸВӘГҸВјГҸВ®' : 'Trending Searches'}\n                  </h3>\n                </div>\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n                  {TRENDING_SEARCHES.map((item) => (\n                    <Link\n                      key={item.slug}\n                      href={`/${locale}/search?q=${encodeURIComponent(item.text)}`}\n                      className=\"flex items-center gap-3 p-2 rounded-lg hover:bg-background-lighter transition-colors\"\n                    >\n                      <span className=\"text-lg\">ВӯЖ’Г¶Г¬</span>\n                      <span>{item.text}</span>\n                    </Link>\n                  ))}\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        )}\n\n        {/* With Query - Show Results */}\n        {query && (\n          <div>\n            <div className=\"mb-6\">\n              <p className=\"text-text-muted\">\n                {locale === 'ar'\n                  ? `в”ҳГҘГҸВ¬ГҸВәГҸВӘГҸВј ГҸВәв”ҳГӨГҸВҝГҸВЎГҸВҪ ГҸв•Јв”ҳГҘ \"${query}\"`\n                  : `Search results for \"${query}\"`}\n                <span className=\"ml-2 text-text\">({results.length} results)</span>\n              </p>\n            </div>\n\n            {/* Suggestions */}\n            {suggestions.length > 0 && (\n              <Card className=\"mb-6 bg-accent-amber/10 border-accent-amber/20\">\n                <CardContent className=\"p-4\">\n                  <p className=\"text-sm font-medium mb-2\">\n                    {locale === 'ar' ? 'в”ҳГ§в”ҳГӨ ГҸВ¬в”ҳГ©ГҸГҒГҸВ»ГҸЖ’' : 'Did you mean?'}\n                  </p>\n                  <div className=\"flex flex-wrap gap-2\">\n                    {suggestions.map((suggestion) => (\n                      <Link\n                        key={suggestion.slug}\n                        href={`/${locale}/search?q=${encodeURIComponent(suggestion.text)}`}\n                      >\n                        <Badge variant=\"accent\" className=\"cursor-pointer\">\n                          {suggestion.text}\n                        </Badge>\n                      </Link>\n                    ))}\n                  </div>\n                </CardContent>\n              </Card>\n            )}\n\n            {/* Results */}\n            {results.length === 0 ? (\n              <Card className=\"p-12 text-center\">\n                <SearchIcon className=\"w-16 h-16 mx-auto mb-4 text-text-muted\" />\n                <h2 className=\"text-xl font-semibold mb-2\">\n                  {locale === 'ar'\n                    ? `в”ҳГӨГҸВә ГҸВ¬в”ҳГӘГҸВјГҸВ» в”ҳГҘГҸВ¬ГҸВәГҸВӘГҸВј в”ҳГӨв”ҳГҮ \"${query}\"`\n                    : `No results for \"${query}\"`}\n                </h2>\n                <p className=\"text-text-muted mb-6\">\n                  {locale === 'ar'\n                    ? 'ГҸВјГҸв–’ГҸВҝ в”ҳГўв”ҳГӨв”ҳГ ГҸВәГҸВ¬ в”ҳГ в”ҳГјГҸВ¬ГҸВәГҸВЎв”ҳГЁГҸВ® в”ҳГ ГҸВ«ГҸВ¬в”ҳГӨв”ҳГјГҸВ® ГҸГәв”ҳГӘ ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВәв”ҳГӨв”ҳГјГҸВӘГҸВәГҸВ¬'\n                    : 'Try different keywords or browse categories'}\n                </p>\n                <Link href={`/${locale}/products`}>\n                  <Button variant=\"outline\">\n                    {locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВјв”ҳГ в”ҳГЁГҸв•Ј ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Browse All Products'}\n                  </Button>\n                </Link>\n              </Card>\n            ) : (\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n                {results.map((product) => (\n                  <Link key={product.id} href={`/${locale}/products/${product.slug}`}>\n                    <Card className=\"group h-full hover:scale-105 transition-transform\">\n                      <CardContent className=\"p-4\">\n                        <div className=\"aspect-square bg-background-lighter rounded-lg mb-3 flex items-center justify-center text-5xl\">\n                          ВӯЖ’Г„В«\n                        </div>\n                        <div className=\"text-xs text-primary mb-1\">\n                          {isRTL ? product.platform.nameAr : product.platform.name}\n                        </div>\n                        <h3 className=\"font-medium mb-2 line-clamp-2 group-hover:text-primary\">\n                          {isRTL ? product.nameAr : product.name}\n                        </h3>\n                        <PriceDisplay\n                          price={product.price}\n                          compareAtPrice={product.compareAtPrice}\n                        />\n                        <RatingStars rating={product.rating} count={product.ratingCount} size=\"sm\" />\n                      </CardContent>\n                    </Card>\n                  </Link>\n                ))}\n              </div>\n            )}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\USER\\Desktop\\RaadFun\\SSS\\ecom\\src\\app\\[locale]\\wishlist\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Locale' is defined but never used.","line":9,"column":15,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":21,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varN