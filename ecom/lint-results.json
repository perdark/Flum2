iption',\n        nameAr: 'ГҸВәГҸв”ӨГҸВ¬ГҸв–’ГҸВәв”ҳГў ГҸв”ӨГҸВәГҸВ¬ ГҸВјв”ҳГЁ ГҸВҝв”ҳГЁ ГҸВ¬в”ҳГЁ ГҸВҝв”ҳГӨГҸв”Ӯ',\n        platform: 'AI',\n        platformAr: 'ГҸв–‘в”ҳГўГҸВәГҸГӯ ГҸВәГҸГҒГҸГҖв”ҳГҘГҸВәГҸв•Јв”ҳГЁ',\n        image: '/chatgpt.jpg',\n        deliveryType: 'contact',\n        price: 20,\n      },\n    ],\n    total: 20,\n    currency: 'USD',\n  },\n];\n\nconst STATUS_CONFIG = {\n  pending: {\n    label: 'Pending',\n    labelAr: 'в”ҳГ©в”ҳГЁГҸВ» ГҸВәв”ҳГӨГҸВәв”ҳГҘГҸВ¬ГҸВ©ГҸВәГҸв–’',\n    variant: 'warning' as const,\n    icon: 'Г”Г…в”Ӯ',\n  },\n  processing: {\n    label: 'Processing',\n    labelAr: 'в”ҳГ©в”ҳГЁГҸВ» ГҸВәв”ҳГӨв”ҳГ ГҸв•ЈГҸВәв”ҳГӨГҸВјГҸВ®',\n    variant: 'info' as const,\n    icon: 'Г”ГңГ–ВҙВ©Г…',\n  },\n  delivered: {\n    label: 'Delivered',\n    labelAr: 'ГҸВ¬в”ҳГ  ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӨв”ҳГЁв”ҳГ ',\n    variant: 'success' as const,\n    icon: 'Г”ВЈГҙ',\n  },\n  cancelled: {\n    label: 'Cancelled',\n    labelAr: 'в”ҳГ в”ҳГӨГҸв•‘в”ҳГЁ',\n    variant: 'error' as const,\n    icon: 'Г”ВЈГІ',\n  },\n};\n\nexport async function generateMetadata({ params }: OrdersPageProps): Promise<Metadata> {\n  const { locale } = await params;\n  return {\n    title: locale === 'ar' ? 'ГҸГҖв”ҳГӨГҸВҝГҸВәГҸВ¬в”ҳГЁ' : 'My Orders',\n  };\n};\n\nexport default async function OrdersPage({ params }: OrdersPageProps) {\n  const { locale } = await params;\n  const isRTL = locale === 'ar';\n\n  return (\n    <div className=\"min-h-screen py-8\">\n      <div className=\"container mx-auto px-4\">\n        {/* Header */}\n        <div className=\"mb-8\">\n          <h1 className=\"text-3xl font-bold mb-2\">\n            {locale === 'ar' ? 'ГҸГҖв”ҳГӨГҸВҝГҸВәГҸВ¬в”ҳГЁ' : 'My Orders'}\n          </h1>\n          <p className=\"text-text-muted\">\n            {locale === 'ar'\n              ? 'ГҸв•ЈГҸв–’ГҸГӮ в”ҳГӘГҸВ¬ГҸВ¬ГҸВҝГҸв•Ј ГҸВјв”ҳГ в”ҳГЁГҸв•Ј ГҸГҖв”ҳГӨГҸВҝГҸВәГҸВ¬в”ҳГў'\n              : 'View and track all your orders'}\n          </p>\n        </div>\n\n        {ORDERS.length === 0 ? (\n          <Card className=\"p-12 text-center\">\n            <Package className=\"w-16 h-16 mx-auto mb-4 text-text-muted\" />\n            <h2 className=\"text-xl font-semibold mb-2\">\n              {locale === 'ar' ? 'в”ҳГӨГҸВә ГҸВ¬в”ҳГӘГҸВјГҸВ» ГҸГҖв”ҳГӨГҸВҝГҸВәГҸВ¬ ГҸВҝГҸв•ЈГҸВ»' : 'No orders yet'}\n            </h2>\n            <p className=\"text-text-muted mb-6\">\n              {locale === 'ar'\n                ? 'ГҸВәГҸВҝГҸВ»ГҸГә ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӘв”ҳГ© в”ҳГӘГҸв”ӮГҸВ¬ГҸВ©в”ҳГ§ГҸв–’ ГҸГҖв”ҳГӨГҸВҝГҸВәГҸВ¬в”ҳГў в”ҳГ§в”ҳГҘГҸВә'\n                : 'Start shopping and your orders will appear here'}\n            </p>\n            <Link href={`/${locale}/products`}>\n              <Button variant=\"primary\">\n                {locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Browse Products'}\n              </Button>\n            </Link>\n          </Card>\n        ) : (\n          <div className=\"space-y-6\">\n            {ORDERS.map((order) => {\n              const status = STATUS_CONFIG[order.status as keyof typeof STATUS_CONFIG];\n\n              return (\n                <Card key={order.id}>\n                  <CardContent className=\"p-6\">\n                    {/* Order Header */}\n                    <div className=\"flex items-start justify-between mb-4\">\n                      <div>\n                        <div className=\"flex items-center gap-3 mb-1\">\n                          <h3 className=\"font-semibold text-lg\">{order.id}</h3>\n                          <Badge variant={status.variant}>\n                            {status.icon} {isRTL ? status.labelAr : status.label}\n                          </Badge>\n                        </div>\n                        <p className=\"text-sm text-text-muted\">\n                          {new Date(order.date).toLocaleDateString(\n                            locale === 'ar' ? 'ar-SA' : 'en-US',\n                            { year: 'numeric', month: 'long', day: 'numeric' }\n                          )}\n                        </p>\n                      </div>\n                      <div className=\"text-right\">\n                        <p className=\"font-semibold\">\n                          {order.currency} {order.total.toFixed(2)}\n                        </p>\n                        <Link href={`/${locale}/profile/orders/${order.id}`}>\n                          <Button variant=\"ghost\" size=\"sm\">\n                            <Eye className=\"w-4 h-4 mr-2\" />\n                            {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ¬в”ҳГјГҸВәГҸГҒв”ҳГЁв”ҳГӨ' : 'Details'}\n                          </Button>\n                        </Link>\n                      </div>\n                    </div>\n\n                    <Separator className=\"my-4\" />\n\n                    {/* Order Items */}\n                    <div className=\"space-y-3\">\n                      {order.items.map((item) => (\n                        <div key={item.id} className=\"flex items-center gap-4\">\n                          <div className=\"w-16 h-16 bg-background-lighter rounded-lg flex items-center justify-center text-3xl flex-shrink-0\">\n                            ВӯЖ’Г„В«\n                          </div>\n                          <div className=\"flex-1 min-w-0\">\n                            <h4 className=\"font-medium line-clamp-1\">\n                              {isRTL ? item.nameAr : item.name}\n                            </h4>\n                            <p className=\"text-sm text-text-muted\">\n                              {isRTL ? item.platformAr : item.platform}\n                            </p>\n                          </div>\n                          <div className=\"text-right\">\n                            <p className=\"font-medium\">\n                              {order.currency} {item.price.toFixed(2)}\n                            </p>\n                            {order.status === 'delivered' && (\n                              <Button variant=\"outline\" size=\"sm\" className=\"mt-1\">\n                                <Download className=\"w-3 h-3 mr-1\" />\n                                {locale === 'ar' ? 'ГҸВ¬ГҸВЎв”ҳГ в”ҳГЁв”ҳГӨ' : 'Download'}\n                              </Button>\n                            )}\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n\n                    {/* Order Actions */}\n                    {order.status === 'pending' && (\n                      <div className=\"mt-4 pt-4 border-t border-border/50 flex justify-end gap-2\">\n                        <Button variant=\"outline\" size=\"sm\">\n                          {locale === 'ar' ? 'ГҸГ‘в”ҳГӨГҸв•‘ГҸВәГҸГӯ ГҸВәв”ҳГӨГҸГҖв”ҳГӨГҸВҝ' : 'Cancel Order'}\n                        </Button>\n                        <Button variant=\"primary\" size=\"sm\">\n                          {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ»в”ҳГјГҸв•Ј ГҸВәв”ҳГӨГҸГів”ҳГҘ' : 'Pay Now'}\n                        </Button>\n                      </div>\n                    )}\n                  </CardContent>\n                </Card>\n              );\n            })}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\USER\\Desktop\\RaadFun\\SSS\\ecom\\src\\app\\[locale]\\search\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'cn' is defined but never used.","line":10,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"cn"},"fix":{"range":[461,495],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Locale' is defined but never used.","line":11,"column":15,"nodeType":"Identifier","messageId":"unusedVar","endLine":11,"endColumn":21,"suggest