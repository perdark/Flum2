alue: 'price_high', label: 'Price: High to Low', labelAr: 'ГҸВәв”ҳГӨГҸв”ӮГҸв•ЈГҸв–’: в”ҳГ в”ҳГҘ ГҸВәв”ҳГӨГҸГәГҸв•Јв”ҳГӨв”ҳГ« в”ҳГӨв”ҳГӨГҸГәв”ҳГ©в”ҳГӨ' },\n  { value: 'popular', label: 'Popularity', labelAr: 'ГҸВәв”ҳГӨГҸв”ӨГҸв•ЈГҸВҝв”ҳГЁГҸВ®' },\n  { value: 'rating', label: 'Rating', labelAr: 'ГҸВәв”ҳГӨГҸВ¬в”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ ' },\n];\n\nexport async function generateMetadata({ params }: ProductsPageProps): Promise<Metadata> {\n  const { locale } = await params;\n  return {\n    title: locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ | в”ҳГјв”ҳГӘв”ҳГӨв”ҳГ в”ҳГҘ ГҸГ‘в”ҳГ ГҸВҝГҸВәв”ҳГЁГҸв–’' : 'Products | Fulmen Empire',\n    description: locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВјв”ҳГ в”ҳГЁГҸв•Ј в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬в”ҳГҘГҸВә' : 'Browse all our products',\n  };\n}\n\nexport default async function ProductsPage({\n  params,\n  searchParams,\n}: ProductsPageProps) {\n  const { locale } = await params;\n  const search = await searchParams;\n\n  const isRTL = locale === 'ar';\n  const sort = (search.sort as string) || 'newest';\n  const category = search.category as string | undefined;\n  const platform = search.platform as string | undefined;\n  const minPrice = search.minPrice ? Number(search.minPrice) : undefined;\n  const maxPrice = search.maxPrice ? Number(search.maxPrice) : undefined;\n  const minRating = search.minRating ? Number(search.minRating) : undefined;\n\n  // Filter products\n  let filtered = [...PRODUCTS];\n  if (category) {\n    filtered = filtered.filter((p) => p.platform.slug === category);\n  }\n  if (platform) {\n    filtered = filtered.filter((p) => p.platform.slug === platform);\n  }\n  if (minPrice !== undefined) {\n    filtered = filtered.filter((p) => p.price >= minPrice);\n  }\n  if (maxPrice !== undefined) {\n    filtered = filtered.filter((p) => p.price <= maxPrice);\n  }\n  if (minRating !== undefined) {\n    filtered = filtered.filter((p) => p.rating >= minRating);\n  }\n\n  // Sort products\n  switch (sort) {\n    case 'price_low':\n      filtered.sort((a, b) => a.price - b.price);\n      break;\n    case 'price_high':\n      filtered.sort((a, b) => b.price - a.price);\n      break;\n    case 'rating':\n      filtered.sort((a, b) => b.rating - a.rating);\n      break;\n    case 'popular':\n      filtered.sort((a, b) => b.ratingCount - a.ratingCount);\n      break;\n    case 'newest':\n    default:\n      filtered.sort((a, b) => (b.isNew ? 1 : 0) - (a.isNew ? 1 : 0));\n      break;\n  }\n\n  const buildUrl = (params: Record<string, string | undefined>) => {\n    const searchParams = new URLSearchParams();\n    Object.entries(params).forEach(([key, value]) => {\n      if (value) searchParams.set(key, value);\n    });\n    const queryString = searchParams.toString();\n    return queryString ? `?${queryString}` : '';\n  };\n\n  const activeFilters = {\n    category,\n    platform,\n    minPrice: minPrice?.toString(),\n    maxPrice: maxPrice?.toString(),\n    minRating: minRating?.toString(),\n  };\n\n  const hasActiveFilters = Object.values(activeFilters).some((v) => v !== undefined);\n\n  return (\n    <div className=\"min-h-screen\">\n      {/* Page Header */}\n      <section className=\"py-12 border-b border-border/50\">\n        <div className=\"container mx-auto px-4\">\n          <div className=\"max-w-3xl\">\n            <h1 className=\"text-4xl md:text-5xl font-bold mb-4\">\n              {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Products'}\n            </h1>\n            <p className=\"text-text-muted text-lg\">\n              {locale === 'ar'\n                ? 'ГҸВәв”ҳГўГҸВ¬ГҸв”Өв”ҳГј в”ҳГ ГҸВјв”ҳГ в”ҳГӘГҸв•ЈГҸВ¬в”ҳГҘГҸВә ГҸВәв”ҳГӨв”ҳГӘГҸВәГҸв”ӮГҸв•ЈГҸВ® в”ҳГ в”ҳГҘ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ ГҸВәв”ҳГӨГҸв–’в”ҳГ©в”ҳГ в”ҳГЁГҸВ® ГҸВәв”ҳГӨв”ҳГ ГҸВ¬в”ҳГ в”ҳГЁГҸв–“ГҸВ®'\n                : 'Discover our wide collection of premium digital products'}\n            </p>\n          </div>\n\n          {/* Quick Stats */}\n          <div className=\"flex flex-wrap gap-6 mt-8\">\n            <div>\n              <span className=\"text-2xl font-bold text-primary\">{filtered.length}</span>\n              <span className=\"text-text-muted ml-2\">\n                {locale === 'ar' ? 'в”ҳГ в”ҳГҘГҸВ¬ГҸВј' : 'products'}\n              </span>\n            </div>\n            {hasActiveFilters && (\n              <Link href={`/${locale}/products`}>\n                <Badge variant=\"outline\" className=\"gap-1 cursor-pointer hover:bg-background-lighter\">\n                  <X className=\"w-3 h-3\" />\n                  {locale === 'ar' ? 'в”ҳГ ГҸв”ӮГҸВЎ ГҸВәв”ҳГӨв”ҳГјв”ҳГӨГҸВәГҸВ¬ГҸв–’' : 'Clear filters'}\n                </Badge>\n              </Link>\n            )}\n          </div>\n        </div>\n      </section>\n\n      <div className=\"container mx-auto px-4 py-8\">\n        <div className=\"flex flex-col lg:flex-row gap-8\">\n          {/* Filters Sidebar */}\n          <aside className=\"lg:w-72 flex-shrink-0\">\n            <div className=\"sticky top-24 space-y-6\">\n              {/* Mobile Filter Button */}\n              <div className=\"lg:hidden\">\n                <Button variant=\"outline\" className=\"w-full gap-2\">\n                  <Filter className=\"w-4 h-4\" />\n                  {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГјв”ҳГӨГҸВәГҸВ¬ГҸв–’' : 'Filters'}\n                  <ChevronDown className=\"w-4 h-4 ml-auto\" />\n                </Button>\n              </div>\n\n              {/* Filter Card */}\n              <Card className=\"hidden lg:block\">\n                <CardContent className=\"p-6 space-y-6\">\n                  {/* Categories */}\n                  <div>\n                    <h3 className=\"font-semibold mb-4 flex items-center gap-2\">\n                      <span className=\"w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-sm\">\n                        ВӯЖ’ГҙГј\n                      </span>\n                      {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГјГҸВӘГҸВәГҸВ¬' : 'Categories'}\n                    </h3>\n                    <div className=\"space-y-2\">\n                      {FILTERS.categories.map((cat) => (\n                        <Link\n                          key={cat.id}\n                          href={buildUrl({\n                            ...activeFilters,\n                            category: cat.id === category ? '' : cat.id,\n                          })}\n                          className={cn(\n                            'flex items-center justify-between p-2 rounded-lg transition-colors',\n                            category === cat.id\n                              ? 'bg-primary/10 text-primary font-medium'\n                              : 'hover:bg-background-lighter'\n                          )}\n                        >\n                          <span className=\"flex items-center gap-2\">\n                            <span>{cat.icon}</span>\n                            <span className=\"text-sm\">{isRTL ? cat.nameAr : cat.name}</span>\n                          </span>\n                          <span className=\"text-xs text-text-muted bg-background-lighter px-2 py-0.5 rounded-full\">\n                            {cat.count}\n                          </span>\n                        </Link>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Platforms */}\n                  <div className=\"pt-4 border-t border-border/50\">\n                    <h3 className=\"font-semibold mb-4 flex items-center gap-2\">\n                      <span className=\"w-8 h-8 rounded-lg bg-accent-amber/10 flex items-center justify-center text-sm\">\n                        ВӯЖ’Г„В«\n                      </span>\n                      {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸГҒГҸВәГҸВ¬' : 'Platforms'}\n                    </h3>\n                    <div className=\"space-y-2\">\n                      {FILTERS.platforms.map((plat) => (\n                        <Link\n                          key={plat.id}\n                          href={buildUrl({\n                            ...activeFilters,\n                            platform: plat.id === platform ? '' : plat.id,\n                          })}\n                          className={cn(\n                            'flex items-center justify-between p-2 rounded-lg transition-colors',\n                            platform === plat.id\n                              ? 'bg-primary/10 text-primary font-medium'\n                              : 'hover:bg-background-lighter'\n                          )}\n                        >\n                          <span className=\"flex items-center gap-2\">\n                            <span>{plat.icon}</span>\n                            <span className=\"text-sm\">{isRTL ? plat.nameAr : plat.name}</span>\n                          </span>\n                          <span className=\"text-xs text-text-muted bg-background-lighter px-2 py-0.5 rounded-full\">\n                            {plat.count}\n                          </span>\n                        </Link>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Price Range */}\n                  <div className=\"pt-4 border-t border-border/50\">\n                    <h3 className=\"font-semibold mb-4 flex items-center gap-2\">\n                      <span className=\"w-8 h-8 rounded-lg bg-success/10 flex items-center justify-center text-sm\">\n                        ВӯЖ’ГҶв–‘\n                      </span>\n                      {locale === 'ar' ? 'в”ҳГҘГҸГҖГҸВәв”ҳГ© ГҸВәв”ҳГӨГҸв”ӮГҸв•ЈГҸв–’' : 'Price Range'}\n                    </h3>\n                    <div className=\"space-y-2\">\n                      {FILTERS.priceRanges.map((range) => {\n                        const isActive =\n                          minPrice === range.min && maxPrice === range.max;\n                        return (\n                          <Link\n                            key={range.id}\n                            href={buildUrl({\n                              ...activeFilters,\n                              minPrice: range.min === 0 ? '' : String(range.min),\n                              maxPrice: range.max === Infinity ? '' : String(range.max),\n                            })}\n                            className={cn(\n                              'block p-2 rounded-lg transition-colors text-sm',\n                              isActive\n                                ? 'bg-primary/10 text-primary font-medium'\n                                : 'hover:bg-background-lighter text-text-muted'\n                            )}\n                          >\n                            {isRTL ? range.nameAr : range.name}\n                          </Link>\n                        );\n                      })}\n                    </div>\n                  </div>\n\n                  {/* Rating */}\n                  <div className=\"pt-4 border-t border-border/50\">\n                    <h3 className=\"font-semibold mb-4 flex items-center gap-2\">\n                      <span className=\"w-8 h-8 rounded-lg bg-accent-orange/10 flex items-center justify-center text-sm\">\n                        Г”ВЎГү\n                      </span>\n                      {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ¬в”ҳГ©в”ҳГЁв”ҳГЁв”ҳГ ' : 'Rating'}\n                    </h3>\n                    <div className=\"space-y-2\">\n                      {FILTERS.ratings.map((rating) => (\n                        <Link\n                          key={rating.id}\n                          href={buildUrl({\n                            ...activeFilters,\n                            minRating:\n                              rating.value === minRating ? '' : String(rating.value),\n                          })}\n                          className={cn(\n                            'flex items-center gap-2 p-2 rounded-lg transition-colors',\n                            minRating === rating.value\n                              ? 'bg-primary/10 text-primary font-medium'\n                              : 'hover:bg-background-lighter text-text-muted'\n                          )}\n                        >\n                          <div className=\"flex\">\n                            {[1, 2, 3, 4, 5].map((star) => (\n                              <span\n                                key={star}\n                                className={cn(\n                                  star <= rating.value\n                                    ? 'text-accent-amber'\n                                    : 'text-text-muted'\n                                )}\n                              >\n                                Г”ГҝГ \n                              </span>\n                            ))}\n                          </div>\n                          <span className=\"text-sm\">{isRTL ? rating.nameAr : rating.name}</span>\n                        </Link>\n                      ))}\n                    </div>\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n          </aside>\n\n          {/* Products Grid */}\n          <div className=\"flex-1 space-y-6\">\n            {/* Sort & View Bar */}\n            <div className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4\">\n              {/* View Toggle */}\n              <div className=\"flex items-center gap-2 bg-card rounded-lg p-1 border border-border/50\">\n                <button className=\"p-2 rounded-md bg-primary text-white\">\n                  <Grid3x3 className=\"w-4 h-4\" />\n                </button>\n                <button className=\"p-2 rounded-md text-text-muted hover:text-text transition-colors\">\n                  <List className=\"w-4 h-4\" />\n                </button>\n              </div>\n\n              {/* Sort Dropdown */}\n              <div className=\"flex items-center gap-3\">\n                <span className=\"text-sm text-text-muted\">\n                  {locale === 'ar' ? 'ГҸВ¬ГҸв–’ГҸВ¬в”ҳГЁГҸВҝ ГҸВЎГҸв”ӮГҸВҝ:' : 'Sort by:'}\n                </span>\n                <div className=\"relative\">\n                  <select\n                    value={sort}\n                    onChange={(e) => {\n                      window.location.href = buildUrl({\n                        ...activeFilters,\n                        sort: e.target.value,\n                      });\n                    }}\n                    className={cn(\n                      'appearance-none pr-10 pl-4 py-2 bg-card border border-border rounded-lg',\n                      'focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all',\n                      'text-sm font-medium cursor-pointer'\n                    )}\n                  >\n                    {SORT_OPTIONS.map((option) => (\n                      <option key={option.value} value={option.value}>\n                        {isRTL ? option.labelAr : option.label}\n                      </option>\n                    ))}\n                  </select>\n                  <ChevronDown className=\"absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none\" />\n                </div>\n              </div>\n            </div>\n\n            {/* Active Filters Pills */}\n            {hasActiveFilters && (\n              <div className=\"flex flex-wrap items-center gap-2 p-4 bg-card rounded-xl border border-border/50\">\n                <span className=\"text-sm font-medium text-text-muted\">\n                  {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГјв”ҳГӨГҸВәГҸВ¬ГҸв–’ ГҸВәв”ҳГӨв”ҳГҘГҸв”ӨГҸГҖГҸВ®:' : 'Active Filters:'}\n                </span>\n                {category && (\n                  <Badge variant=\"outline\" className=\"gap-1\">\n                    {isRTL\n                      ? FILTERS.categories.find((c) => c.id === category)?.nameAr\n                      : FILTERS.categories.find((c) => c.id === category)?.name}\n                    <Link href={buildUrl({ ...activeFilters, category: '' })}>\n                      <X className=\"w-3 h-3 hover:text-error\" />\n                    </Link>\n                  </Badge>\n                )}\n                {platform && (\n                  <Badge variant=\"outline\" className=\"gap-1\">\n                    {isRTL\n                      ? FILTERS.platforms.find((p) => p.id === platform)?.nameAr\n                      : FILTERS.platforms.find((p) => p.id === platform)?.name}\n                    <Link href={buildUrl({ ...activeFilters, platform: '' })}>\n                      <X className=\"w-3 h-3 hover:text-error\" />\n                    </Link>\n                  </Badge>\n                )}\n                {(minPrice || maxPrice) && (\n                  <Badge variant=\"outline\" className=\"gap-1\">\n                    ${minPrice || 0} - ${maxPrice || 'Г”ГӘГ—'}\n                    <Link\n                      href={buildUrl({ ...activeFilters, minPrice: '', maxPrice: '' })}\n                    >\n                      <X className=\"w-3 h-3 hover:text-error\" />\n                    </Link>\n                  </Badge>\n                )}\n                {minRating && (\n                  <Badge variant=\"outline\" className=\"gap-1\">\n                    {minRating}+ {locale === 'ar' ? 'в”ҳГҘГҸВјв”ҳГӘв”ҳГ ' : 'stars'}\n                    <Link href={buildUrl({ ...activeFilters, minRating: '' })}>\n                      <X className=\"w-3 h-3 hover:text-error\" />\n                    </Link>\n                  </Badge>\n                )}\n                <Link href={`/${locale}/products`}>\n                  <Button variant=\"ghost\" size=\"sm\">\n                    {locale === 'ar' ? 'в”ҳГ ГҸв”ӮГҸВЎ ГҸВәв”ҳГӨв”ҳГўв”ҳГӨ' : 'Clear All'}\n                  </Button>\n                </Link>\n              </div>\n            )}\n\n            {/* Products Grid */}\n            {filtered.length === 0 ? (\n              <Card className=\"p-12 text-center\">\n                <div className=\"w-20 h-20 mx-auto mb-6 rounded-full bg-background-lighter flex items-center justify-center\">\n                  <Filter className=\"w-10 h-10 text-text-muted\" />\n                </div>\n                <h3 className=\"text-xl font-semibold mb-2\">\n                  {locale === 'ar' ? 'в”ҳГӨГҸВә ГҸВ¬в”ҳГӘГҸВјГҸВ» в”ҳГҘГҸВ¬ГҸВәГҸВӘГҸВј' : 'No results found'}\n                </h3>\n                <p className=\"text-text-muted mb-6 max-w-md mx-auto\">\n                  {locale === 'ar'\n                    ? 'в”ҳГӨв”ҳГ  в”ҳГҘГҸВјГҸВ» ГҸГәв”ҳГЁ в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ ГҸВ¬ГҸГҖГҸВәГҸВҝв”ҳГ© в”ҳГјв”ҳГӨГҸВәГҸВ¬ГҸв–’в”ҳГў ГҸВәв”ҳГӨГҸВЎГҸВәв”ҳГӨв”ҳГЁГҸВ®. ГҸВЎГҸВәв”ҳГӘв”ҳГӨ ГҸВ¬ГҸв•ЈГҸВ»в”ҳГЁв”ҳГӨ ГҸВәв”ҳГӨв”ҳГјв”ҳГӨГҸВәГҸВ¬ГҸв–’ в”ҳГӨв”ҳГӨГҸв•ЈГҸВҪв”ҳГӘГҸв–’ ГҸв•Јв”ҳГӨв”ҳГ« в”ҳГ ГҸВә ГҸВ¬ГҸВҝГҸВЎГҸВҪ ГҸв•Јв”ҳГҘв”ҳГ§.'\n                    : \"We couldn't find any products matching your filters. Try adjusting your filters to find what you're looking for.\"}\n                </p>\n                <Link href={`/${locale}/products`}>\n                  <Button variant=\"outline\">\n                    {locale === 'ar' ? 'в”ҳГ ГҸв”ӮГҸВЎ ГҸВәв”ҳГӨв”ҳГјв”ҳГӨГҸВәГҸВ¬ГҸв–’' : 'Clear Filters'}\n                  </Button>\n                </Link>\n              </Card>\n            ) : (\n              <>\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6\">\n                  {filtered.map((product) => (\n                    <ProductCard key={product.id} product={product} locale={locale} />\n                  ))}\n                </div>\n\n                {/* Pagination */}\n                <div className=\"flex justify-center pt-8\">\n                  <div className=\"flex items-center gap-2\">\n                    <Button variant=\"outline\" size=\"sm\" disabled>\n                      {locale === 'ar'