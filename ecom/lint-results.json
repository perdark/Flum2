</div>\n                  <div className=\"flex items-center justify-between text-sm\">\n                    <span className=\"text-text-muted\">\n                      {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸГӮГҸв–’в”ҳГЁГҸВҝГҸВ®' : 'Tax'}\n                    </span>\n                    <CurrencyDisplay amount={tax} />\n                  </div>\n                  {pointsEarned > 0 && (\n                    <div className=\"flex items-center justify-between text-sm text-accent-amber\">\n                      <span>\n                        {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГҘв”ҳГ©ГҸВәГҸГҖ ГҸВәв”ҳГӨГҸВ¬в”ҳГЁ ГҸв”ӮГҸВ¬в”ҳГўГҸв”ӮГҸВҝв”ҳГ§ГҸВә' : 'Points Earned'}\n                      </span>\n                      <span>+{pointsEarned} Г”ГңГӯ</span>\n                    </div>\n                  )}\n                  <Separator />\n                  <div className=\"flex items-center justify-between text-lg font-semibold\">\n                    <span>{locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ ГҸВјв”ҳГ в”ҳГӘГҸв•Ј' : 'Total'}</span>\n                    <CurrencyDisplay amount={total} />\n                  </div>\n                </div>\n\n                {/* Submit Order */}\n                <Button size=\"lg\" variant=\"primary\" className=\"w-full btn-electric\">\n                  <Lock className=\"w-4 h-4 mr-2\" />\n                  {locale === 'ar' ? 'ГҸВ¬ГҸГәв”ҳГўв”ҳГЁГҸВ» ГҸВәв”ҳГӨГҸГҖв”ҳГӨГҸВҝ' : 'Place Order'}\n                  <ArrowRight className={cn('w-5 h-5 ml-2', isRTL && 'rotate-180')} />\n                </Button>\n\n                {/* Terms */}\n                <p className=\"text-xs text-text-muted text-center\">\n                  {locale === 'ar'\n                    ? 'ГҸВҝГҸГ‘ГҸВ¬в”ҳГ ГҸВәв”ҳГ  ГҸВәв”ҳГӨГҸГҖв”ҳГӨГҸВҝ ГҸГәв”ҳГҘГҸВ¬ ГҸВ¬в”ҳГӘГҸВәв”ҳГјв”ҳГ© ГҸв•Јв”ҳГӨв”ҳГ« '\n                    : 'By placing your order you agree to our '}\n                  <Link href={`/${locale}/terms`} className=\"text-primary hover:underline\">\n                    {locale ===