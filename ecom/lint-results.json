ҳГ ГҸВҝГҸВәв”ҳГЁГҸв–’' : 'Shopping Cart | Fulmen Empire',\n    description: locale === 'ar' ? 'ГҸв–’ГҸВәГҸВјГҸв•Ј ГҸв”Ӯв”ҳГӨГҸВ® ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӘв”ҳГ© ГҸВәв”ҳГӨГҸВ«ГҸВәГҸГҒГҸВ® ГҸВҝв”ҳГў' : 'Review your shopping cart',\n  };\n}\n\nexport default async function CartPage({ params }: CartPageProps) {\n  const { locale } = await params;\n  const isRTL = locale === 'ar';\n\n  // Calculate totals\n  const subtotal = CART_ITEMS.reduce(\n    (sum, item) => sum + item.product.price * item.quantity,\n    0\n  );\n  const discount = CART_ITEMS.reduce(\n    (sum, item) =>\n      sum +\n      ((item.product.compareAtPrice || item.product.price) - item.product.price) *\n        item.quantity,\n    0\n  );\n  const tax = 0; // No tax for digital products\n  const total = subtotal - discount + tax;\n  const totalPoints = CART_ITEMS.reduce(\n    (sum, item) => sum + item.pointsReward * item.quantity,\n    0\n  );\n\n  return (\n    <div className=\"min-h-screen\">\n      {/* Page Header */}\n      <section className=\"py-8 border-b border-border/50\">\n        <div className=\"container mx-auto px-4\">\n          <div className=\"flex items-center gap-3 text-sm text-text-muted mb-4\">\n            <Link href={`/${locale}`} className=\"hover:text-primary transition-colors\">\n              {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸв–’ГҸВӘв”ҳГЁГҸв”Ӯв”ҳГЁГҸВ®' : 'Home'}\n            </Link>\n            <span>/</span>\n            <span className=\"text-text\">\n              {locale === 'ar' ? 'ГҸв”Ӯв”ҳГӨГҸВ® ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӘв”ҳГ©' : 'Shopping Cart'}\n            </span>\n          </div>\n\n          <div className=\"flex items-center justify-between\">\n            <div>\n              <h1 className=\"text-3xl md:text-4xl font-bold mb-2\">\n                {locale === 'ar' ? 'ГҸв”Ӯв”ҳГӨГҸВ® ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӘв”ҳГ©' : 'Shopping Cart'}\n              </h1>\n              <p className=\"text-text-muted\">\n                {locale === 'ar'\n                  ? `${CART_ITEMS.length} в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ в”ҳГјв”ҳГЁ ГҸв”Ӯв”ҳГӨГҸВ¬в”ҳГў`\n                  : `${CART_ITEMS.length} item${CART_ITEMS.length > 1 ? 's' : ''} in your cart`}\n              </p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {CART_ITEMS.length === 0 ? (\n        <section className=\"py-20\">\n          <div className=\"container mx-auto px-4\">\n            <Card className=\"max-w-lg mx-auto p-12 text-center\">\n              <div className=\"w-24 h-24 mx-auto mb-6 rounded-full bg-background-lighter flex items-center justify-center\">\n                <ShoppingBag className=\"w-12 h-12 text-text-muted\" />\n              </div>\n              <h2 className=\"text-2xl font-bold mb-3\">\n                {locale === 'ar' ? 'ГҸв”Ӯв”ҳГӨГҸВ® ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӘв”ҳГ© в”ҳГјГҸВәГҸв–’ГҸв•‘ГҸВ®' : 'Your cart is empty'}\n              </h2>\n              <p className=\"text-text-muted mb-8\">\n                {locale === 'ar'\n                  ? 'в”ҳГЁГҸВҝГҸВ»в”ҳГӘ ГҸГәв”ҳГҘв”ҳГў в”ҳГӨв”ҳГ  ГҸВ¬ГҸГӮв”ҳГј ГҸГәв”ҳГЁ в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ ГҸВҝГҸв•ЈГҸВ». ГҸВәГҸВҝГҸВ»ГҸГә ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӘв”ҳГ© ГҸВәв”ҳГӨГҸГів”ҳГҘ!'\n                  : \"Looks like you haven't added any products yet. Start shopping now!\"}\n              </p>\n              <Link href={`/${locale}/products`}>\n                <Button variant=\"primary\" size=\"lg\" className=\"btn-electric gap-2\">\n                  {locale === 'ar' ? 'ГҸВ¬ГҸГҒв”ҳГјГҸВЎ ГҸВәв”ҳГӨв”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬' : 'Browse Products'}\n                  <ArrowRight className={cn('w-5 h-5', isRTL && 'rotate-180')} />\n                </Button>\n              </Link>\n            </Card>\n          </div>\n        </section>\n      ) : (\n        <section className=\"py-8\">\n          <div className=\"container mx-auto px-4\">\n            <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n              {/* Cart Items */}\n              <div className=\"lg:col-span-2 space-y-6\">\n                {CART_ITEMS.map((item, index) => (\n                  <CartItem key={item.id} item={item} locale={locale} index={index} />\n                ))}\n              </div>\n\n              {/* Order Summary Sidebar */}\n              <div className=\"lg:col-span-1\">\n                <div className=\"sticky top-24 space-y-6\">\n                  {/* Order Summary Card */}\n                  <Card className=\"card-glow\">\n                    <CardContent className=\"p-6\">\n                      <h2 className=\"text-xl font-bold mb-6 flex items-center gap-2\">\n                        <Shield className=\"w-5 h-5 text-primary\" />\n                        {locale === 'ar' ? 'в”ҳГ в”ҳГӨГҸВ«ГҸГҒ ГҸВәв”ҳГӨГҸГҖв”ҳГӨГҸВҝ' : 'Order Summary'}\n                      </h2>\n\n                      {/* Coupon Code */}\n                      <div className=\"mb-6\">\n                        <label className=\"text-sm font-medium mb-2 block\">\n                          {locale === 'ar' ? 'в”ҳГўв”ҳГӘГҸВ» ГҸВәв”ҳГӨГҸВ«ГҸГҒв”ҳГ ' : 'Coupon Code'}\n                        </label>\n                        <div className=\"flex gap-2\">\n                          <input\n                            type=\"text\"\n                            placeholder={locale === 'ar' ? 'ГҸГәГҸВ»ГҸВ«в”ҳГӨ ГҸВәв”ҳГӨв”ҳГўв”ҳГӘГҸВ»' : 'Enter code'}\n                            className={cn(\n                              'flex-1 px-4 py-3 bg-background border border-border rounded-xl',\n                              'focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all',\n                              'placeholder:text-text-muted text-sm'\n                            )}\n                          />\n                          <Button variant=\"outline\" className=\"shrink-0\">\n                            {locale === 'ar' ? 'ГҸВ¬ГҸГҖГҸВҝв”ҳГЁв”ҳГ©' : 'Apply'}\n                          </Button>\n                        </div>\n                      </div>\n\n                      {/* Price Breakdown */}\n                      <div className=\"space-y-4 mb-6\">\n                        <div className=\"flex items-center justify-between text-sm\">\n                          <span className=\"text-text-muted\">\n                            {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ ГҸВјв”ҳГ в”ҳГӘГҸв•Ј ГҸВәв”ҳГӨв”ҳГјГҸв–’ГҸв•Јв”ҳГЁ' : 'Subtotal'}\n                          </span>\n                          <CurrencyDisplay amount={subtotal} />\n                        </div>\n\n                        {discount > 0 && (\n                          <div className=\"flex items-center justify-between text-sm\">\n                            <span className=\"text-success\">\n                              {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ«ГҸГҒв”ҳГ ' : 'Discount'}\n                            </span>\n                            <span className=\"text-success font-medium\">\n                              -<CurrencyDisplay amount={discount} />\n                            </span>\n                          </div>\n                        )}\n\n                        <div className=\"flex items-center justify-between text-sm\">\n                          <span className=\"text-text-muted\">\n                            {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸГӮГҸв–’в”ҳГЁГҸВҝГҸВ®' : 'Tax'}\n                          </span>\n                          <span>{locale === 'ar' ? 'ГҸв•‘в”ҳГЁГҸв–’ в”ҳГ ГҸГҖГҸВҝв”ҳГ©' : 'N/A'}</span>\n                        </div>\n\n                        {totalPoints > 0 && (\n                          <div className=\"flex items-center justify-between p-3 bg-accent-amber/10 rounded-xl\">\n                            <span className=\"text-sm font-medium text-accent-amber flex items-center gap-2\">\n                              <Zap className=\"w-4 h-4\" />\n                              {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГҘв”ҳГ©ГҸВәГҸГҖ ГҸВәв”ҳГӨв”ҳГ в”ҳГўГҸв”ӮГҸВҝГҸВ®' : 'Points Earned'}\n                            </span>\n                            <span className=\"font-bold text-accent-amber\">\n                              +{totalPoints}\n                            </span>\n                          </div>\n                        )}\n                      </div>\n\n                      {/* Total */}\n                      <div className=\"border-t border-border/50 pt-4 mb-6\">\n                        <div className=\"flex items-center justify-between\">\n                          <span className=\"text-lg font-bold\">\n                            {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ ГҸВјв”ҳГ в”ҳГӘГҸв•Ј' : 'Total'}\n                          </span>\n                          <CurrencyDisplay\n                            amount={total}\n                            className=\"text-2xl font-bold text-primary\"\n                          />\n                        </div>\n                        {discount > 0 && (\n                          <p className=\"text-xs text-success mt-1\">\n                            {locale === 'ar'\n                              ? `ГҸВ¬в”ҳГӘв”ҳГјГҸв–’ $${discount.toFixed(2)} ГҸв•Јв”ҳГӨв”ҳГ« в”ҳГ§ГҸв–‘ГҸВә ГҸВәв”ҳГӨГҸГҖв”ҳГӨГҸВҝ`\n                              : `You save $${discount.toFixed(2)} on this order`}\n                          </p>\n                        )}\n                      </div>\n\n                      {/* Checkout Button */}\n                      <Link href={`/${locale}/checkout`} className=\"block\">\n                        <Button\n                          variant=\"primary\"\n                          size=\"lg\"\n                          className=\"w-full btn-electric lightning-glow gap-2\"\n                        >\n                          {locale === 'ar' ? 'ГҸГ‘ГҸВ¬в”ҳГ ГҸВәв”ҳГ  ГҸВәв”ҳГӨГҸв”ӨГҸв–’ГҸВәГҸГӯ' : 'Proceed to Checkout'}\n                          <ArrowRight className={cn('w-5 h-5', isRTL && 'rotate-180')} />\n                        </Button>\n                      </Link>\n\n                      <Link href={`/${locale}/products`}>\n                        <Button variant=\"ghost\" className=\"w-full\">\n                          {locale === 'ar' ? 'в”ҳГ ГҸВ¬ГҸВәГҸВҝГҸв•ЈГҸВ® ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӘв”ҳГ©' : 'Continue Shopping'}\n                        </Button>\n                      </Link>\n                    </CardContent>\n                  </Card>\n\n                  {/* Trust Badges */}\n                  <Card className=\"border-border/50\">\n                    <CardContent className=\"p-6\">\n                      <div className=\"grid grid-cols-3 gap-4 text-center\">\n                        <div className=\"space-y-2\">\n                          <div className=\"w-12 h-12 mx-auto rounded-xl bg-primary/10 flex items-center justify-center\">\n                            <Shield className=\"w-6 h-6 text-primary\" />\n                          </div>\n                          <p className=\"text-xs font-medium\">\n                            {locale === 'ar' ? 'ГҸВ»в”ҳГјГҸв•Ј ГҸГів”ҳГ в”ҳГҘ' : 'Secure Payment'}\n                          </p>\n                        </div>\n                        <div className=\"space-y-2\">\n                          <div className=\"w-12 h-12 mx-auto rounded-xl bg-accent-amber/10 flex items-center justify-center\">\n                            <Zap className=\"w-6 h-6 text-accent-amber\" />\n                          </div>\n                          <p className=\"text-xs font-medium\">\n                            {locale === 'ar' ? 'ГҸВ¬в”ҳГӘГҸГҒв”ҳГЁв”ҳГӨ в”ҳГјв”ҳГӘГҸв–’в”ҳГЁ' : 'Instant Delivery'}\n                          </p>\n                        </div>\n                        <div className=\"space-y-2\">\n                          <div className=\"w-12 h-12 mx-auto rounded-xl bg-success/10 flex items-center justify-center\">\n                            <Truck className=\"w-6 h-6 text-success\" />\n                          </div>\n                          <p className=\"text-xs font-medium\">\n                            {locale === 'ar' ? 'ГҸВ»ГҸв•Јв”ҳГ  24/7' : '24/7 Support'}\n                          </p>\n                        </div>\n                      </div>\n                    </CardContent>\n                  </Card>\n                </div>\n              </div>\n            </div>\n\n            {/* Recommended Products */}\n            {RECOMMENDED_PRODUCTS.length > 0 && (\n              <section className=\"mt-16\">\n                <div className=\"flex items-center justify-between mb-8\">\n                  <div>\n                    <h2 className=\"text-2xl font-bold mb-1\">\n                      {locale === 'ar' ? 'в”ҳГ©ГҸВ» в”ҳГЁГҸв•ЈГҸВјГҸВҝв”ҳГў ГҸГәв”ҳГЁГҸГӮГҸВәв”ҳГҜ' : 'You might also like'}\n                    </h2>\n                    <p className=\"text-text-muted text-sm\">\n                      {locale === 'ar'\n                        ? 'в”ҳГ в”ҳГҘГҸВ¬ГҸВјГҸВәГҸВ¬ в”ҳГ в”ҳГӘГҸГҒв”ҳГ« ГҸВҝв”ҳГ§ГҸВә ГҸВҝв”ҳГҘГҸВәГҸГӯв”ҳГҜ ГҸв•Јв”ҳГӨв”ҳГ« ГҸв”Ӯв”ҳГӨГҸВ¬в”ҳГў'\n                        : 'Recommended products based on your cart'}\n                    </p>\n                  </div>\n                  <Link href={`/${locale}/products`}>\n                    <Button variant=\"ghost\" className=\"gap-2\">\n                      {locale === 'ar' ? 'ГҸв•ЈГҸв–’ГҸГӮ ГҸВәв”ҳГӨв”ҳГўв”ҳГӨ' : 'View All'}\n                      <ArrowRight className={cn('w-4 h-4', isRTL && 'rotate-180')} />\n                    </Button>\n                  </Link>\n                </div>\n\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n                  {RECOMMENDED_PRODUCTS.map((product) => (\n                    <RecommendedProduct key={product.id} product={product} locale={locale} />\n                  ))}\n                </div>\n              </section>\n            )}\n          </div>\n        </section>\n      )}\n    </div>\n  );\n}\n\nfunction CartItem({\n  item,\n  locale,\n  index,\n}: {\n  item: typeof CART_ITEMS[number];\n  locale: string;\n  index: number;\n}) {\n  const isRTL = locale === 'ar';\n\n  return (\n    <Card className=\"card-interactive overflow-hidden animate-slide-up\" style={{ animationDelay: `${index * 100}ms` }}>\n      <CardContent className=\"p-0\">\n        <div className=\"flex flex-col sm:flex-row gap-4 p-4\">\n          {/* Product Image */}\n          <Link\n            href={`/${locale}/products/${item.product.slug}`}\n            className=\"shrink-0\"\n          >\n            <div className=\"relative w-full sm:w-28 aspect-square sm:aspect-auto sm:h-28 bg-background-lighter rounded-xl overflow-hidden\">\n              <div className=\"absolute inset-0 flex items-center justify-center text-4xl\">\n                {item.product.platform.slug === 'steam' && 'ВӯЖ’Г„В«'}\n                {item.product.platform.slug === 'netflix' && 'ВӯЖ’Г„Вј'}\n                {item.product.platform.slug === 'ai' && 'ВӯЖ’ГұГ»'}\n              </div>\n              {/* Quantity Badge */}\n              <div className=\"absolute top-2 left-2 px-2 py-1 bg-background/90 backdrop-blur-sm rounded-lg text-xs font-medium\">\n                в”ңГ№{item.quantity}\n              </div>\n            </div>\n          </Link>\n\n          {/* Product Info */}\n          <div className=\"flex-1 min-w-0\">\n            <div className=\"flex items-start justify-between gap-4\">\n              <div className=\"min-w-0 flex-1\">\n                <div className=\"flex items-center gap-2 mb-1\">\n                  <Badge variant=\"outline\" size=\"sm\">\n                    {isRTL\n                      ? item.product.platform.nameAr\n                      : item.product.platform.name}\n                  </Badge>\n                  {item.product.deliveryType === 'auto_key' && (\n                    <Badge variant=\"success\" size=\"sm\">\n                      {locale === 'ar' ? 'ГҸВ¬в”ҳГӘГҸГҒв”ҳГЁв”ҳГӨ в”ҳГјв”ҳГӘГҸв–’в”ҳГЁ' : 'Instant'}\n                    </Badge>\n                  )}\n                </div>\n                <Link href={`/${locale}/products/${item.product.slug}`}>\n                  <h3 className=\"font-semibold hover:text-primary transition-colors line-clamp-1 mb-1\">\n                    {isRTL ? item.product.nameAr : item.product.name}\n                  </h3>\n                </Link>\n\n                <div className=\"flex items-center gap-3 flex-wrap\">\n                  <PriceDisplay\n                    price={item.product.price}\n                    compareAtPrice={item.product.compareAtPrice}\n                  />\n                  {item.pointsReward > 0 && (\n                    <span className=\"text-xs text-accent-amber flex items-center gap-0.5\">\n                      <Zap className=\"w-3 h-3\" />\n                      +{item.pointsReward * item.quantity}\n                    </span>\n                  )}\n                </div>\n              </div>\n\n              <Button\n                variant=\"ghost\"\n                size=\"sm\"\n                className=\"text-text-muted hover:text-error hover:bg-error/10 shrink-0\"\n              >\n                <Trash2 className=\"w-4 h-4\" />\n              </Button>\n            </div>\n\n            {/* Quantity Controls & Total */}\n            <div className=\"flex items-center justify-between mt-4 pt-4 border-t border-border/50\">\n              <div className=\"flex items-center border border-border rounded-xl overflow-hidden\">\n                <button\n                  className=\"w-10 h-10 flex items-center justify-center hover:bg-background-lighter transition-colors\"\n                  aria-label={locale === 'ar' ? 'ГҸГ‘в”ҳГҘв”ҳГ©ГҸВәГҸГҒ' : 'Decrease'}\n                >\n                  <Minus className=\"w-4 h-4\" />\n                </button>\n                <span className=\"w-12 text-center font-medium\">{item.quantity}</span>\n                <button\n                  className=\"w-10 h-10 flex items-center justify-center hover:bg-background-lighter transition-colors\"\n                  aria-label={locale === 'ar' ? 'ГҸв–“в”ҳГЁГҸВәГҸВ»ГҸВ®' : 'Increase'}\n                >\n                  <Plus className=\"w-4 h-4\" />\n                </button>\n              </div>\n\n              <div className=\"text-right\">\n                <p className=\"text-xs text-text-muted mb-0.5\">\n                  {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸГ‘ГҸВјв”ҳГ ГҸВәв”ҳГӨв”ҳГЁ' : 'Total'}\n                </p>\n                <CurrencyDisplay\n                  amount={item.product.price * item.quantity}\n                  className=\"text-lg font-bold\"\n                />\n              </div>\n            </div>\n          </div>\n        </div>\n      </CardContent>\n    </Card>\n  );\n}\n\nfunction RecommendedProduct({\n  product,\n  locale,\n}: {\n  product: typeof RECOMMENDED_PRODUCTS[number];\n  locale: string;\n}) {\n  const isRTL = locale === 'ar';\n\n  return (\n    <Link href={`/${locale}/products/${product.slug}`} className=\"block group\">\n      <Card className=\"card-glow h-full\">\n        <CardContent className=\"p-4\">\n          {/* Image */}\n          <div className=\"relative aspect-square bg-background-lighter rounded-xl overflow-hidden mb-4\">\n            <div className=\"absolute inset-0 flex items-center justify-center text-5xl group-hover:scale-110 transition-transform duration-300\">\n              {product.platform.slug === 'playstation' && 'ВӯЖ’Г„В»'}\n              {product.platform.slug === 'xbox' && 'ВӯЖ’Ж’Гі'}\n            </div>\n\n            {/* Quick Add Button */}\n            <button className=\"absolute bottom-2 right-2 w-10 h-10 rounded-xl bg-primary text-white opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center\">\n              <Plus className=\"w-5 h-5\" />\n            </button>\n          </div>\n\n          {/* Content */}\n          <div className=\"space-y-2\">\n            <p className=\"text-xs text-primary\">\n              {isRTL ? product.platform.nameAr : product.platform.name}\n            </p>\n            <h3 className=\"font-semibold line-clamp-2 group-hover:text-primary transition-colors\">\n              {isRTL ? product.nameAr : product.name}\n            </h3>\n            <div className=\"flex items-center justify-between\">\n              <PriceDisplay price={product.price} compareAtPrice={product.compareAtPrice} />\n              {product.pointsReward > 0 && (\n                <span className=\"text-xs text-accent-amber\">\n                  +{product.pointsReward} Г”ГңГӯ\n                </span>\n              )}\n            </div>\n          </div>\n        </CardContent>\n      </Card>\n    </Link>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\USER\\Desktop\\RaadFun\\SSS\\ecom\\src\\app\\[locale]\\checkout\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'PriceDisplay' is defined but never used.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":22,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"PriceDisplay"},"fix":{"range":[333,346],"text":""},"desc":"Remove unused variable \"PriceDisplay\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Locale' is defined but never used.","line":10,"column":15,"nodeType":"Identifier","messageId":"unusedVar","endLine":10,"endColumn":21,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Locale"},"fix":{"range":[487,529],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Metadata } from 'next';\nimport Link from 'next/link';\nimport { CreditCard, MessageCircle, Lock, ArrowRight } from 'lucide-react';\nimport { Button } from '@/components/ui/button';\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\nimport { Separator } from '@/components/ui/separator';\nimport { PriceDisplay, CurrencyDisplay } from '@/components/ui/currency-display';\nimport { Input } from '@/components/ui/input';\nimport { cn } from '@/lib/utils';\nimport type { Locale } from '@/lib/i18n';\n\ninterface CheckoutPageProps {\n  params: Promise<{ locale: string }>;\n}\n\n// Mock order data\nconst ORDER_ITEMS = [\n  {\n    id: '1',\n    name: 'Elden Ring',\n    nameAr: 'ГҸГ‘в”ҳГӨГҸВ»в”ҳГҘ ГҸв–’в”ҳГЁв”ҳГҘГҸВј',\n    platform: 'Steam',\n    platformAr: 'ГҸв”ӮГҸВ¬в”ҳГЁв”ҳГ ',\n    price: 59.99,\n    quantity: 1,\n    deliveryType: 'auto_key',\n  },\n  {\n    id: '2',\n    name: 'Netflix Premium 1 Month',\n    nameAr: 'в”ҳГҘГҸВ¬в”ҳГјв”ҳГӨв”ҳГЁв”ҳГўГҸв”Ӯ ГҸВҝГҸв–’в”ҳГЁв”ҳГ в”ҳГЁв”ҳГӘв”ҳГ  ГҸв”Өв”ҳГ§ГҸв–’',\n    platform: 'Netflix',\n    platformAr: 'в”ҳГҘГҸВ¬в”ҳГјв”ҳГӨв”ҳГЁв”ҳГўГҸв”Ӯ',\n    price: 15.99,\n    quantity: 2,\n    deliveryType: 'auto_account',\n  },\n];\n\nexport async function generateMetadata({ params }: CheckoutPageProps): Promise<Metadata> {\n  const { locale } = await params;\n  return {\n    title: locale === 'ar' ? 'ГҸГ‘ГҸВ¬в”ҳГ ГҸВәв”ҳГ  ГҸВәв”ҳГӨГҸв”ӨГҸв–’ГҸВәГҸГӯ' : 'Checkout',\n  };\n};\n\nexport default async function CheckoutPage({ params }: CheckoutPageProps) {\n  const { locale } = await params;\n  const isRTL = locale === 'ar';\n\n  const subtotal = ORDER_ITEMS.reduce((sum, item) => sum + item.price * item.quantity, 0);\n  const tax = 0;\n  const total = subtotal + tax;\n  const pointsEarned = Math.floor(total);\n\n  return (\n    <div className=\"min-h-screen py-8\">\n      <div className=\"container mx-auto px-4\">\n        {/* Header */}\n        <div className=\"mb-8\">\n          <h1 className=\"text-3xl font-bold mb-2\">\n            {locale === 'ar' ? 'ГҸГ‘ГҸВ¬в”ҳГ ГҸВәв”ҳГ  ГҸВәв”ҳГӨГҸв”ӨГҸв–’ГҸВәГҸГӯ' : 'Checkout'}\n          </h1>\n          <p className=\"text-text-muted\">\n            {locale === 'ar'\n              ? 'ГҸГәв”ҳГўв”ҳГ в”ҳГӨ ГҸГҖв”ҳГӨГҸВҝв”ҳГў в”ҳГјв”ҳГЁ ГҸВҝГҸГӮГҸв•Ј ГҸВ«ГҸГҖв”ҳГӘГҸВәГҸВ¬ ГҸВҝГҸв”Ӯв”ҳГЁГҸГҖГҸВ®'\n              : 'Complete your order in a few simple steps'}\n          </p>\n        </div>\n\n        {/* Progress Steps */}\n        <div className=\"flex items-center justify-center mb-12\">\n          <div className=\"flex items-center gap-4\">\n            <div className=\"flex items-center gap-2\">\n              <div className=\"w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white font-semibold\">\n                1\n              </div>\n              <span className=\"font-medium hidden sm:inline\">\n                {locale === 'ar' ? 'ГҸВәв”ҳГӨв”ҳГ ГҸв•Јв”ҳГӨв”ҳГӘв”ҳГ ГҸВәГҸВ¬' : 'Information'}\n              </span>\n            </div>\n            <div className=\"w-16 h-0.5 bg-border\" />\n            <div className=\"flex items-center gap-2\">\n              <div className=\"w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white font-semibold\">\n                2\n              </div>\n              <span className=\"font-medium hidden sm:inline\">\n                {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ»в”ҳГјГҸв•Ј' : 'Payment'}\n              </span>\n            </div>\n            <div className=\"w-16 h-0.5 bg-border\" />\n            <div className=\"flex items-center gap-2\">\n              <div className=\"w-8 h-8 rounded-full bg-border flex items-center justify-center text-text-muted\">\n                3\n              </div>\n              <span className=\"text-text-muted hidden sm:inline\">\n                {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ¬ГҸГәв”ҳГўв”ҳГЁГҸВ»' : 'Confirmation'}\n              </span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\n          {/* Checkout Form */}\n          <div className=\"lg:col-span-2 space-y-6\">\n            {/* Contact Information */}\n            <Card>\n              <CardHeader>\n                <CardTitle className=\"text-lg\">\n                  {locale === 'ar' ? 'в”ҳГ ГҸв•Јв”ҳГӨв”ҳГӘв”ҳГ ГҸВәГҸВ¬ ГҸВәв”ҳГӨГҸВәГҸВ¬ГҸГҒГҸВәв”ҳГӨ' : 'Contact Information'}\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"space-y-4\">\n                <div>\n                  <label className=\"text-sm font-medium mb-2 block\">\n                    {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВҝГҸв–’в”ҳГЁГҸВ» ГҸВәв”ҳГӨГҸГ‘в”ҳГӨв”ҳГўГҸВ¬ГҸв–’в”ҳГӘв”ҳГҘв”ҳГЁ' : 'Email'}\n                  </label>\n                  <Input\n                    type=\"email\"\n                    placeholder={locale === 'ar' ? 'ГҸВҝГҸв–’в”ҳГЁГҸВ»в”ҳГў@example.com' : 'your@email.com'}\n                    required\n                  />\n                </div>\n                <p className=\"text-sm text-text-muted\">\n                  {locale === 'ar'\n                    ? 'ГҸв”Ӯв”ҳГЁГҸВ¬в”ҳГ  ГҸГ‘ГҸв–’ГҸв”ӮГҸВәв”ҳГӨ ГҸВ¬ГҸГәв”ҳГўв”ҳГЁГҸВ» ГҸВәв”ҳГӨГҸГҖв”ҳГӨГҸВҝ в”ҳГӘГҸв•Јв”ҳГҘГҸВәГҸГҒГҸв–’ ГҸВәв”ҳГӨГҸВ¬ГҸв”Ӯв”ҳГӨв”ҳГЁв”ҳГ  ГҸГ‘в”ҳГӨв”ҳГ« в”ҳГ§ГҸв–‘ГҸВә ГҸВәв”ҳГӨГҸВҝГҸв–’в”ҳГЁГҸВ»'\n                    : 'Order confirmation and delivery items will be sent to this email'}\n                </p>\n              </CardContent>\n            </Card>\n\n            {/* Payment Method */}\n            <Card>\n              <CardHeader>\n                <CardTitle className=\"text-lg\">\n                  {locale === 'ar' ? 'ГҸГҖГҸв–’в”ҳГЁв”ҳГ©ГҸВ® ГҸВәв”ҳГӨГҸВ»в”ҳГјГҸв•Ј' : 'Payment Method'}\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"space-y-4\">\n                {/* Card Payment */}\n                <label className=\"flex items-start gap-4 p-4 border-2 border-primary rounded-lg cursor-pointer bg-primary/5\">\n                  <input\n                    type=\"radio\"\n                    name=\"payment\"\n                    value=\"card\"\n                    defaultChecked\n                    className=\"mt-1\"\n                  />\n                  <div className=\"flex-1\">\n                    <div className=\"flex items-center gap-2 mb-1\">\n                      <CreditCard className=\"w-5 h-5 text-primary\" />\n                      <span className=\"font-semibold\">\n                        {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ»в”ҳГјГҸв•Ј ГҸВҝГҸВәв”ҳГӨГҸВҝГҸГҖГҸВәв”ҳГ©ГҸВ®' : 'Card Payment'}\n                      </span>\n                    </div>\n                    <p className=\"text-sm text-text-muted\">\n                      {locale === 'ar'\n                        ? 'ГҸВәГҸВ»в”ҳГјГҸв•Ј ГҸВҝГҸГәв”ҳГ ГҸВәв”ҳГҘ ГҸВҝГҸВәГҸв”ӮГҸВ¬ГҸВ«ГҸВ»ГҸВәв”ҳГ  ГҸВҝГҸГҖГҸВәв”ҳГ©ГҸВ¬в”ҳГў ГҸВәв”ҳГӨГҸВәГҸВӘГҸВ¬в”ҳГ ГҸВәв”ҳГҘв”ҳГЁГҸВ® ГҸГәв”ҳГӘ ГҸВәв”ҳГӨГҸВҝв”ҳГҘв”ҳГўв”ҳГЁГҸВ®'\n                        : 'Pay securely using your credit or debit card'}\n                    </p>\n                  </div>\n                  <div className=\"flex gap-1\">\n                    <div className=\"w-10 h-6 bg-white rounded flex items-center justify-center text-[10px] text-black font-bold\">\n                      VISA\n                    </div>\n                    <div className=\"w-10 h-6 bg-white rounded flex items-center justify-center text-[10px] text-black font-bold\">\n                      MC\n                    </div>\n                  </div>\n                </label>\n\n                {/* Manual Contact */}\n                <label className=\"flex items-start gap-4 p-4 border-2 border-border rounded-lg cursor-pointer hover:border-primary/50 transition-colors\">\n                  <input type=\"radio\" name=\"payment\" value=\"contact\" className=\"mt-1\" />\n                  <div className=\"flex-1\">\n                    <div className=\"flex items-center gap-2 mb-1\">\n                      <MessageCircle className=\"w-5 h-5\" />\n                      <span className=\"font-semibold\">\n                        {locale === 'ar' ? 'ГҸВәв”ҳГӨГҸВ»в”ҳГјГҸв•Ј ГҸв•ЈГҸ