ount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Metadata } from 'next';\r\nimport Link from 'next/link';\r\nimport { User, Mail, Lock, Eye, EyeOff, Zap, Check, Gift } from 'lucide-react';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Logo } from '@/components/ui/logo';\r\nimport { cn } from '@/lib/utils';\r\nimport type { Locale } from '@/lib/i18n';\r\n\r\ninterface SignupPageProps {\r\n  params: Promise<{ locale: string }>;\r\n}\r\n\r\nexport async function generateMetadata({\r\n  params,\r\n}: SignupPageProps): Promise<Metadata> {\r\n  const { locale } = await params;\r\n  return {\r\n    title: locale === 'ar' ? 'ГҸГ‘в”ҳГҘГҸв”ӨГҸВәГҸГӯ ГҸВЎГҸв”ӮГҸВәГҸВҝ | в”ҳГјв”ҳГӘв”ҳГӨв”ҳГ в”ҳГҘ ГҸГ‘в”ҳГ ГҸВҝГҸВәв”ҳГЁГҸв–’' : 'Sign Up | Fulmen Empire',\r\n    description: locale === 'ar'\r\n      ? 'ГҸГәв”ҳГҘГҸв”ӨГҸВӘ ГҸВЎГҸв”ӮГҸВәГҸВҝГҸВәв”ҳГҜ ГҸВјГҸВ»в”ҳГЁГҸВ»ГҸВәв”ҳГҜ в”ҳГјв”ҳГЁ в”ҳГјв”ҳГӘв”ҳГӨв”ҳГ в”ҳГҘ ГҸГ‘в”ҳГ ГҸВҝГҸВәв”ҳГЁГҸв–’'\r\n      : 'Create a new account at Fulmen Empire',\r\n  };\r\n}\r\n\r\nexport default async function SignupPage({ params }: SignupPageProps) {\r\n  const { locale } = await params;\r\n  const isRTL = locale === 'ar';\r\n\r\n  const benefits = [\r\n    {\r\n      icon: Zap,\r\n      title: locale === 'ar' ? 'в”ҳГҘв”ҳГ©ГҸВәГҸГҖ ГҸВәв”ҳГӨв”ҳГӘв”ҳГӨГҸВәГҸГӯ' : 'Loyalty Points',\r\n      description: locale === 'ar'\r\n        ? 'ГҸВәв”ҳГўГҸв”ӮГҸВҝ в”ҳГҘв”ҳГ©ГҸВәГҸГҖ в”ҳГ ГҸв•Ј в”ҳГўв”ҳГӨ ГҸв•Јв”ҳГ в”ҳГӨв”ҳГЁГҸВ® ГҸв”ӨГҸв–’ГҸВәГҸГӯ'\r\n        : 'Earn points with every purchase',\r\n    },\r\n    {\r\n      icon: Gift,\r\n      title: locale === 'ar' ? 'ГҸв•ЈГҸв–’в”ҳГӘГҸГӮ ГҸВЎГҸГҒГҸв–’в”ҳГЁГҸВ®' : 'Exclusive Deals',\r\n      description: locale === 'ar'\r\n        ? 'ГҸВәГҸВЎГҸГҒв”ҳГӨ ГҸв•Јв”ҳГӨв”ҳГ« ГҸв•ЈГҸв–’в”ҳГӘГҸГӮ ГҸВ«ГҸВәГҸГҒГҸВ® в”ҳГӨв”ҳГӨГҸГәГҸв•ЈГҸГӮГҸВәГҸГӯ'\r\n        : 'Get members-only exclusive deals',\r\n    },\r\n    {\r\n      icon: Check,\r\n      title: locale === 'ar' ? 'ГҸВ¬ГҸв”Ӯв”ҳГӨв